<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- 670 astrogen -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>als.biotechgravship</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="MoveSpeed_Space"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Astrogen</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">-1000</displayOrderInCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="BfG_Hemogen_Space"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<prerequisite Operation="SafeAdd">MoveSpeed_Space</prerequisite>
							<displayCategory Operation="AddOrReplace">Astrogen</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">-690</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]/statFactors/HemogenGainFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<HemogenGainFactor Operation="SafeAdd">0.2</HemogenGainFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="BfG_PsychicAbility_Space"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationAttributeRemove">
						<xpath>GeneDef</xpath>
						<attribute>ParentName</attribute>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<biostatArc Operation="SafeRemove"/>
							<prerequisite Operation="SafeAdd">MoveSpeed_Space</prerequisite>
							<displayCategory Operation="AddOrReplace">Astrogen</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">-600</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<PsychicSensitivity Operation="SafeReplace">-0.2</PsychicSensitivity>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<PsychicSensitivity Operation="SafeReplace">0.4</PsychicSensitivity>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.OptionalPatch">
						<modId>FrozenSnowFox.FrozenSnowFoxTweaks</modId>
						<key>FSFPsychicSensBonuses</key>
						<defaultValue>false</defaultValue>
						<caseTrue>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>GeneDef/conditionalStatAffecters/li/statOffsets</xpath>
								<value>
									<MeditationFocusGain Operation="SafeRemove"/>
									<PsychicEntropyRecoveryRate Operation="SafeRemove"/>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="BfG_WoundHealing_Space"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<prerequisite Operation="SafeAdd">MoveSpeed_Space</prerequisite>
							<displayCategory Operation="AddOrReplace">Astrogen</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">-500</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
						<value>
							<statFactors Operation="Safe">
								<InjuryHealingFactor Operation="SafeReplace">0.5</InjuryHealingFactor>
							</statFactors>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]/statFactors</xpath>
						<value>
							<InjuryHealingFactor Operation="SafeRemove"/>
							<ImmunityGainSpeed Operation="SafeRemove"/>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="SafeAdd">1</InjuryHealingFactor>
								<ImmunityGainSpeed Operation="SafeAdd">0.1</ImmunityGainSpeed>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="BfG_MinTemp_Space"]</xpath>
				<value>
					<prerequisite Operation="SafeAdd">MoveSpeed_Space</prerequisite>
					<displayCategory Operation="AddOrReplace">Astrogen</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">-450</displayOrderInCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="BfG_Sleep_Space"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationAttributeRemove">
						<xpath>GeneDef</xpath>
						<attribute>ParentName</attribute>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<prerequisite Operation="SafeAdd">MoveSpeed_Space</prerequisite>
							<displayCategory Operation="AddOrReplace">Astrogen</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">-420</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]/statFactors/RestFallRateFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<RestFallRateFactor Operation="SafeAdd">0.4</RestFallRateFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
						<value>
							<statFactors Operation="Safe">
								<RestFallRateFactor Operation="SafeReplace">0.4</RestFallRateFactor>
							</statFactors>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="BfG_Robust_Space"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<prerequisite Operation="SafeAdd">MoveSpeed_Space</prerequisite>
							<displayCategory Operation="AddOrReplace">Astrogen</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">-370</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]/statFactors/IncomingDamageFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<IncomingDamageFactor Operation="SafeAdd">0.2</IncomingDamageFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="BfG_Learning_Space"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<prerequisite Operation="SafeAdd">MoveSpeed_Space</prerequisite>
							<displayCategory Operation="AddOrReplace">Astrogen</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">-110</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
						<value>
							<statFactors Operation="Safe">
								<GlobalLearningFactor Operation="SafeReplace">0.5</GlobalLearningFactor>
							</statFactors>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]/statFactors/GlobalLearningFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<GlobalLearningFactor Operation="SafeAdd">0.5</GlobalLearningFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- 1000 archite -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>als.biotechgravship</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="BfG_MoveSpeed_SpaceArchite"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<displayOrderInCategory Operation="AddOrReplace">-670</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]/statOffsets</xpath>
						<value>
							<ComfyTemperatureMax Operation="SafeRemove"/>
							<MentalBreakThreshold Operation="SafeRemove"/>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<MoveSpeed Operation="SafeReplace">1</MoveSpeed>
								<WorkSpeedGlobal Operation="SafeReplace">0.1</WorkSpeedGlobal>
								<ImmunityGainSpeed Operation="SafeReplace">0.1</ImmunityGainSpeed>
								<MentalBreakThreshold Operation="SafeReplace">-0.1</MentalBreakThreshold>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
