<?xml version="1.0" encoding="utf-8"?>
<Patch>	

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>als.biotechgravship</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.PatchOperationAttributeRemove">
				<xpath>Defs/GeneDef[defName="BfG_Sleep_Space"]</xpath>
				<attribute>ParentName</attribute>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/GeneDef[defName="BfG_Sleep_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]/statFactors/RestFallRateFactor</xpath>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_Sleep_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
				<value>
					<statOffsets>
						<RestFallRateFactor>0.4</RestFallRateFactor>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_Sleep_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
				<value>
					<statFactors>
						<RestFallRateFactor>0.4</RestFallRateFactor>
					</statFactors>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/GeneDef[defName="BfG_Robust_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]/statFactors/IncomingDamageFactor</xpath>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_Robust_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
				<value>
					<statOffsets>
						<IncomingDamageFactor>0.2</IncomingDamageFactor>
					</statOffsets>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_Learning_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
				<value>
					<statFactors>
						<GlobalLearningFactor>0.5</GlobalLearningFactor>
					</statFactors>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/GeneDef[defName="BfG_Learning_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]/statFactors/GlobalLearningFactor</xpath>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_Learning_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
				<value>
					<statOffsets>
						<GlobalLearningFactor>0.5</GlobalLearningFactor>
					</statOffsets>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_WoundHealing_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
				<value>
					<statFactors>
						<InjuryHealingFactor>0.5</InjuryHealingFactor>
					</statFactors>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="BfG_WoundHealing_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]/statFactors</xpath>
				<value>
					<InjuryHealingFactor Operation="SafeRemove"/>
					<ImmunityGainSpeed Operation="SafeRemove"/>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_WoundHealing_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
				<value>
					<statOffsets>
						<InjuryHealingFactor>1</InjuryHealingFactor>
						<ImmunityGainSpeed>0.1</ImmunityGainSpeed>
					</statOffsets>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/GeneDef[defName="BfG_Hemogen_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]/statFactors/HemogenGainFactor</xpath>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_Hemogen_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
				<value>
					<statOffsets>
						<HemogenGainFactor>0.2</HemogenGainFactor>
					</statOffsets>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/GeneDef[defName="BfG_MoveSpeed_SpaceArchite"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]/statOffsets/ComfyTemperatureMax</xpath>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_MoveSpeed_SpaceArchite"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
				<value>
					<statOffsets>
						<WorkSpeedGlobal>0.2</WorkSpeedGlobal>
						<MentalBreakThreshold>0.1</MentalBreakThreshold>
					</statOffsets>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.PatchOperationAttributeRemove">
				<xpath>Defs/GeneDef[defName="BfG_PsychicAbility_Space"]</xpath>
				<attribute>ParentName</attribute>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/GeneDef[defName="BfG_PsychicAbility_Space"]/biostatArc</xpath>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_PsychicAbility_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]</xpath>
				<value>
					<statOffsets>
						<PsychicSensitivity>-0.2</PsychicSensitivity>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
				<xpath>Defs/GeneDef[defName="BfG_PsychicAbility_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]</xpath>
				<value>
					<statOffsets>
						<PsychicSensitivity>0.6</PsychicSensitivity>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.OptionalPatch">
				<modId>FrozenSnowFox.FrozenSnowFoxTweaks</modId>
				<key>FSFPsychicSensBonuses</key>
				<defaultValue>false</defaultValue>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="BfG_PsychicAbility_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_NotInSpace"]/statOffsets</xpath>
						<value>
							<MeditationFocusGain Operation="SafeRemove"/>
							<PsychicEntropyRecoveryRate Operation="SafeRemove"/>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="BfG_PsychicAbility_Space"]/conditionalStatAffecters/li[@Class="ConditionalStatAffecter_InSpace"]/statOffsets</xpath>
						<value>
							<MeditationFocusGain Operation="SafeRemove"/>
							<PsychicEntropyRecoveryRate Operation="SafeRemove"/>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
