					<customEffectDescriptions Operation="SafeAdd">
						<li>Gain stat bonuses when exposed to pollution.</li>
					</customEffectDescriptions>
					<displayOrderInCategory Operation="SafeReplace">-470</displayOrderInCategory>
					<geneClass Operation="SafeRemove"/>
					<modExtensions Operation="Safe">
						<li Class="VEF.Genes.GeneExtension" Operation="Safe">
							<hediffToWholeBody Operation="SafeAdd">PollutionStimulus</hediffToWholeBody>
						</li>
					</modExtensions>
					<prerequisite Operation="SafeAdd">VRE_ToxAbsorption</prerequisite>
