	<!-- 520 cell -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.waster</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="CellInstabilityBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Health_Cell</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_Instability_Nominal"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<LifespanFactor Operation="SafeReplace">0.9</LifespanFactor>
						<CancerRate Operation="SafeReplace">2</CancerRate>
					</statFactors>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="Instability_Mild"]</xpath>
				<value>
