						<CancerRate Operation="SafeReplace">6</CancerRate>
						<ImmunityGainSpeed Operation="SafeReplace">0.90</ImmunityGainSpeed>
					</statFactors>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_Instability_Progressive"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Health_Cell</displayCategory>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
