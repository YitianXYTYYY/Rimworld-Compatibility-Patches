<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- 680 pollution -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.waster</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_ToxAbsorption"]</xpath>
				<value>
					<displayCategory Operation="SafeReplace">VREW_Mutations</displayCategory>
					<displayOrderInCategory Operation="SafeReplace">-1000</displayOrderInCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VREW_PollutionRegeneration"]</xpath>
