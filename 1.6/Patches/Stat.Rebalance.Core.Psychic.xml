<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- stats -->
	<Operation Class="XmlExtensions.HybridPatch">
		<xpath>Defs/StatDef[defName="PsychicSensitivity"]</xpath>
		<value>
			<category Operation="SafeReplace">PawnPsyfocus</category>
		</value>
	</Operation>
	<Operation Class="XmlExtensions.HybridPatch">
		<xpath>Defs/StatDef[defName="PsychicEntropyRecoveryRate"]</xpath>
		<value>
			<defaultBaseValue Operation="SafeReplace">0.6</defaultBaseValue>
		</value>
	</Operation>
	<Operation Class="XmlExtensions.HybridPatch">
		<xpath>Defs/StatDef[defName="PsychicSensitivityOffset"]/parts/li[@Class="StatPart_Quality"]</xpath>
		<value>
			<factorAwful Operation="SafeReplace">0.0</factorAwful>
			<factorPoor Operation="SafeReplace">0.5</factorPoor>
			<factorNormal Operation="SafeReplace">1</factorNormal>
			<factorGood Operation="SafeReplace">1</factorGood>
			<factorExcellent Operation="SafeReplace">1.5</factorExcellent>
			<factorMasterwork Operation="SafeReplace">1.5</factorMasterwork>
			<factorLegendary Operation="SafeReplace">2</factorLegendary>
		</value>
	</Operation>

	<!-- psylink -->
	<Operation Class="XmlExtensions.SetScope">
		<xpath>Defs/HediffDef[defName="PsychicAmplifier"]</xpath>
		<apply>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>HediffDef/stages/li/statFactors/PsychicEntropyMax</xpath>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>HediffDef/stages/li/statFactors/PsychicEntropyRecoveryRate</xpath>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="2"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">10</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.06</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="3"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">20</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.12</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="4"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">30</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.18</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="5"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">40</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.24</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="6"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">50</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.30</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
		</apply>
	</Operation>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>ludeon.rimworld.royalty</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="PsychicSensitizer"]/stages/li/statOffsets</xpath>
				<value>
					<PsychicSensitivity Operation="SafeReplace">0.4</PsychicSensitivity>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>ludeon.rimworld.biotech</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="PsychofluidRush"]/stages/li/statOffsets</xpath>
				<value>
					<PsychicSensitivity Operation="SafeReplace">0.2</PsychicSensitivity>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>ludeon.rimworld.anomaly</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- bioferrite -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="Bioferrite"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>ThingDef/stuffProps/statFactorsQuality/li[stat="PsychicSensitivityFactor"]</xpath>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>ThingDef/stuffProps/statFactorsQuality/li[stat="PsychicEntropyMaxOffset"]</xpath>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>ThingDef/stuffProps/statFactorsQuality/li[stat="PsychicEntropyRecoveryRateOffset"]</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef/stuffProps</xpath>
						<value>
							<statOffsetsQuality Operation="Add">
								<li MayRequireAnyOf="Ludeon.RimWorld.Royalty,Ludeon.RimWorld.Biotech">
									<stat>PsychicSensitivityOffset</stat>
									<awful>0.2</awful>
									<poor>0.2</poor>
									<normal>0.2</normal>
									<good>0.2</good>
									<excellent>0.2</excellent>
									<masterwork>0.2</masterwork>
									<legendary>0.2</legendary>
								</li>
							</statOffsetsQuality>
						</value>
					</Operation>
				</apply>
			</Operation>
			<!-- hediff -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="Voidsight"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/StudyEfficiency</xpath>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/PsychicSensitivity</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li</xpath>
						<value>
							<statOffsets Operation="Safe">
								<StudyEfficiency Operation="SafeAdd">0.2</StudyEfficiency>
								<PsychicSensitivity Operation="SafeAdd">0.4</PsychicSensitivity>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VoidTouched"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/StudyEfficiency</xpath>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/PsychicSensitivity</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li</xpath>
						<value>
							<statOffsets Operation="Safe">
								<StudyEfficiency Operation="SafeAdd">1</StudyEfficiency>
								<PsychicSensitivity Operation="SafeAdd">2</PsychicSensitivity>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="Psychophage"]/stages/li</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicSensitivity Operation="SafeReplace">0.6</PsychicSensitivity>
					</statOffsets>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
