<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- stats -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/StatDef[defName="PsychicSensitivity"]/category</xpath>
		<value>
			<category>PawnPsyfocus</category>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/StatDef[defName="PsychicEntropyRecoveryRate"]/defaultBaseValue</xpath>
		<value>
			<defaultBaseValue>0.6</defaultBaseValue>
		</value>
	</Operation>
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/StatDef[defName = "PsychicSensitivityOffset"]/parts</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/StatDef[defName="PsychicSensitivityOffset"]</xpath>
			<value>
				<parts/>
			</value>
		</nomatch>
	</Operation>
	<Operation Class="PatchOperationConditional">
		<xpath>Defs/StatDef[defName="PsychicSensitivityOffset"]/parts/li[@Class="StatPart_Quality"]</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>Defs/StatDef[defName="PsychicSensitivityOffset"]/parts</xpath>
			<value>
				<li Class="StatPart_Quality"/>
			</value>
		</nomatch>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/StatDef[defName="PsychicSensitivityOffset"]/parts/li[@Class="StatPart_Quality"]</xpath>
		<value>
			<li Class="StatPart_Quality">
				<factorAwful>0.0</factorAwful>
				<factorPoor>0.5</factorPoor>
				<factorNormal>1</factorNormal>
				<factorGood>1</factorGood>
				<factorExcellent>1.5</factorExcellent>
				<factorMasterwork>2</factorMasterwork>
				<factorLegendary>3</factorLegendary>
			</li>
		</value>
	</Operation>

	<!-- bioferrite -->
	<Operation Class="PatchOperationRemove" MayRequire="Ludeon.RimWorld.Anomaly">
		<xpath>Defs/ThingDef[defName="Bioferrite"]/stuffProps/statFactorsQuality/li[stat="PsychicSensitivityFactor"]</xpath>
	</Operation>
	<Operation Class="PatchOperationRemove" MayRequire="Ludeon.RimWorld.Anomaly">
		<xpath>Defs/ThingDef[defName="Bioferrite"]/stuffProps/statOffsetsQuality/li[stat="PsychicEntropyMaxOffset" or stat="PsychicEntropyRecoveryRateOffset"]</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Anomaly">
		<xpath>Defs/ThingDef[defName="Bioferrite"]/stuffProps/statOffsetsQuality</xpath>
		<value>
			<li MayRequireAnyOf="Ludeon.RimWorld.Royalty,Ludeon.RimWorld.Biotech">
			<stat>PsychicSensitivityOffset</stat>
			<awful>0.2</awful>
			<poor>0.2</poor>
			<normal>0.2</normal>
			<good>0.2</good>
			<excellent>0.2</excellent>
			<masterwork>0.2</masterwork>
			<legendary>0.2</legendary>
			</li>
		</value>
	</Operation>

	<!-- apparel -->
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/ThingDef[defName="Apparel_PsychicFoilHelmet"]/equippedStatOffsets/PsychicSensitivity</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Apparel_PsychicFoilHelmet"]/equippedStatOffsets</xpath>
		<value>
			<PsychicSensitivityOffset>-0.9</PsychicSensitivityOffset>
		</value>
	</Operation>

	<!-- eltex -->
	<Operation Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
		<xpath>Defs/ThingDef[defName="Apparel_PsyfocusHelmet" or defName="Apparel_PsyfocusVest"]/equippedStatOffsets/PsychicSensitivityOffset</xpath>
		<value>
			<PsychicSensitivityOffset>0.2</PsychicSensitivityOffset>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
		<xpath>Defs/ThingDef[defName="MeleeWeapon_PsyfocusStaff"]/equippedStatOffsets/PsychicSensitivityOffset</xpath>
		<value>
			<PsychicSensitivityOffset>0.6</PsychicSensitivityOffset>
		</value>
	</Operation>

	<!-- prestige armor -->	
	<Operation Class="PatchOperationRemove" MayRequire="Ludeon.RimWorld.Royalty">
		<xpath>Defs/ThingDef[defName="Apparel_ArmorReconPrestige" or
			defName="Apparel_ArmorHelmetReconPrestige" or 
			defName="Apparel_ArmorMarinePrestige" or 
			defName="Apparel_ArmorMarineHelmetPrestige" or 
			defName="Apparel_ArmorCataphractPrestige" or 
			defName="Apparel_ArmorHelmetCataphractPrestige"]/equippedStatOffsets/PsychicSensitivity</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Royalty">
		<xpath>Defs/ThingDef[defName="Apparel_ArmorReconPrestige" or
			defName="Apparel_ArmorHelmetReconPrestige" or 
			defName="Apparel_ArmorMarinePrestige" or 
			defName="Apparel_ArmorMarineHelmetPrestige" or 
			defName="Apparel_ArmorCataphractPrestige" or 
			defName="Apparel_ArmorHelmetCataphractPrestige"]/equippedStatOffsets</xpath>
		<value>
			<PsychicSensitivityOffset>0.1</PsychicSensitivityOffset>
		</value>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Prestige Specialist Armours Reworked</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="Apparel_ArmorPhoenixPrestige" or defName="Apparel_ArmorLocustPrestige" or defName="Apparel_ArmorGrenadierPrestige"]/equippedStatOffsets/PsychicSensitivity</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="Apparel_ArmorPhoenixPrestige" or defName="Apparel_ArmorLocustPrestige" or defName="Apparel_ArmorGrenadierPrestige"]/equippedStatOffsets</xpath>
					<value>
						<PsychicSensitivityOffset>0.1</PsychicSensitivityOffset>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Armour Expanded</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<!-- industrial -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="VAE_Headgear_HAZMATMask" or defName="VAE_Apparel_HAZMATSuit"]/equippedStatOffsets/PsychicSensitivity</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VAE_Headgear_HAZMATMask"]/equippedStatOffsets</xpath>
					<value>
						<PsychicSensitivityOffset>-0.5</PsychicSensitivityOffset>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_HAZMATSuit"]/equippedStatOffsets</xpath>
					<value>
						<PsychicSensitivityOffset>-0.5</PsychicSensitivityOffset>
					</value>
				</li>
				<!-- spacer -->
				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="VAE_Headgear_RoyalTrooperHelmet" or defName="VAE_Apparel_RoyalTrooperArmor" or defName="VAE_Headgear_RoyalSiegeHelmet" or defName="VAE_Apparel_RoyalSiegeArmor"]/equippedStatOffsets/PsychicSensitivity</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VAE_Headgear_RoyalTrooperHelmet" or defName="VAE_Apparel_RoyalTrooperArmor" or defName="VAE_Headgear_RoyalSiegeHelmet" or defName="VAE_Apparel_RoyalSiegeArmor"]/equippedStatOffsets</xpath>
					<value>
						<PsychicSensitivityOffset>0.1</PsychicSensitivityOffset>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Archon</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="VREA_Apparel_Archoplate"]/equippedStatOffsets/PsychicSensitivity</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VREA_Apparel_Archoplate"]/equippedStatOffsets</xpath>
					<value>
						<PsychicSensitivityOffset>0.6</PsychicSensitivityOffset>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

</Patch>
