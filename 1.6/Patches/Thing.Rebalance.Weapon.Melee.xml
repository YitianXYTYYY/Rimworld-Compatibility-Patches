<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>Ludeon.RimWorld.Royalty</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="MeleeWeapon_PsyfocusStaff"]</xpath>
				<value>
					<equippedStatOffsets Operation="Safe">
						<PsychicSensitivityOffset Operation="SafeReplace">0.8</PsychicSensitivityOffset>
					</equippedStatOffsets>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- Vanilla Weapons Expanded -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaexpanded.vwe</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="VWE_MeleeWeapon_Shovel" or 
					defName="VWE_MeleeWeapon_Baton" or 
					defName="VWE_MeleeWeapon_CombatKnife"]</xpath>
				<value>
					<recipeMaker Operation="Safe">
						<researchPrerequisite Operation="SafeReplace">Machining</researchPrerequisite>
					</recipeMaker>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
