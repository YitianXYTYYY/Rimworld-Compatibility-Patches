<?xml version="1.0" encoding="utf-8"?>
<Patch>	

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Pigskin</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[defName="VRE_RapidAging"]/statFactors/VEF_GrowthPointMultiplier</xpath>
					<value>
						<VEF_GrowthPointMultiplier>4</VEF_GrowthPointMultiplier>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[defName="VRE_FastAging"]/statFactors/VEF_GrowthPointMultiplier</xpath>
					<value>
						<VEF_GrowthPointMultiplier>2</VEF_GrowthPointMultiplier>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[defName="VRE_ExtraMeat" or defName="VRE_LowMeat"]/biostatCpx</xpath>
					<value>
						<biostatCpx>1</biostatCpx>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[defName="VRE_ExtraMeat"]/statFactors/MeatAmount</xpath>
					<value>
						<MeatAmount>1.5</MeatAmount>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[defName="VRE_LowMeat"]/statFactors/MeatAmount</xpath>
					<value>
						<MeatAmount>0.5</MeatAmount>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

</Patch>
