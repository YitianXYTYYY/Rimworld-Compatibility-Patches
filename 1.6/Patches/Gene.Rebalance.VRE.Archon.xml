<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.archon</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- 600 psychic -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_HighEntropyCapacity"]</xpath>
				<value>
					<biostatCpx Operation="SafeReplace">1</biostatCpx>
					<biostatMet Operation="SafeReplace">-2</biostatMet>
					<statFactors Operation="Safe">
						<PsychicEntropyMax Operation="SafeRemove">0</PsychicEntropyMax>
					</statFactors>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">10</PsychicEntropyMax>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_ExtremeEntropyCapacity"]</xpath>
				<value>
					<biostatCpx Operation="SafeReplace">2</biostatCpx>
					<biostatMet Operation="SafeReplace">-5</biostatMet>
					<statFactors Operation="Safe">
						<PsychicEntropyMax Operation="SafeRemove">0</PsychicEntropyMax>
					</statFactors>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">20</PsychicEntropyMax>
					</statOffsets>
				</value>
			</Operation>

			<!-- 590 meditation -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_SlowMeditation"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Psychic_Meditation</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">0</displayOrderInCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_SwiftMeditation"]</xpath>
				<value>
					<biostatCpx Operation="SafeRemove"/>
					<biostatMet Operation="SafeReplace">-2</biostatMet>
					<displayCategory Operation="AddOrReplace">Psychic_Meditation</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">10</displayOrderInCategory>
					<statFactors Operation="Safe">
						<MeditationFocusGain Operation="SafeRemove">0</MeditationFocusGain>
					</statFactors>
					<statOffsets Operation="Safe">
						<MeditationFocusGain Operation="SafeAdd">0.1</MeditationFocusGain>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_ExtremeMeditation"]</xpath>
				<value>
					<biostatCpx Operation="SafeReplace">2</biostatCpx>
					<biostatMet Operation="SafeReplace">-5</biostatMet>
					<displayCategory Operation="AddOrReplace">Psychic_Meditation</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">20</displayOrderInCategory>
					<statFactors Operation="Safe">
						<MeditationFocusGain Operation="SafeRemove">0</MeditationFocusGain>
					</statFactors>
					<statOffsets Operation="Safe">
						<MeditationFocusGain Operation="SafeAdd">0.2</MeditationFocusGain>
					</statOffsets>
				</value>
			</Operation>

			<!-- 390 ranged -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_SlowShooter"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Violence_Ranged</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">10</displayOrderInCategory>
					<statFactors Operation="Safe">
						<RangedCooldownFactor Operation="SafeRemove">0</RangedCooldownFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<RangedCooldownFactor Operation="SafeAdd">0.2</RangedCooldownFactor>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_FastShooter"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Violence_Ranged</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">20</displayOrderInCategory>
				</value>
			</Operation>

			<!-- 380 melee -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_SlowMeleeHitter"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Violence_Melee</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">100</displayOrderInCategory>
					<statFactors Operation="Safe">
						<MeleeCooldownFactor Operation="SafeRemove">0</MeleeCooldownFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<MeleeCooldownFactor Operation="SafeAdd">0.2</MeleeCooldownFactor>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_FastMeleeHitter"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Violence_Melee</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">110</displayOrderInCategory>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
