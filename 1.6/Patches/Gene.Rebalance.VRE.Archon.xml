<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.archon</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_PsychicAbility_MoreExtreme"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicSensitivity Operation="SafeReplace">0.8</PsychicSensitivity>
					</statOffsets>
				</value>
			</Operation>

			<!-- 600 psychic -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VRE_HighEntropyCapacity"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<biostatCpx Operation="SafeReplace">1</biostatCpx>
							<biostatMet Operation="SafeReplace">-2</biostatMet>
							<statOffsets Operation="Safe">
								<PsychicEntropyMax Operation="SafeAdd">10</PsychicEntropyMax>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/PsychicEntropyMax</xpath>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VRE_ExtremeEntropyCapacity"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<biostatCpx Operation="SafeReplace">2</biostatCpx>
							<biostatMet Operation="SafeReplace">-5</biostatMet>
							<statOffsets Operation="Safe">
								<PsychicEntropyMax Operation="SafeAdd">20</PsychicEntropyMax>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/PsychicEntropyMax</xpath>
					</Operation>
				</apply>
			</Operation>

			<!-- 590 meditation -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VRE_SwiftMeditation"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<biostatCpx Operation="SafeReplace">1</biostatCpx>
							<biostatMet Operation="SafeReplace">-1</biostatMet>
							<statOffsets Operation="Safe">
								<MeditationFocusGain Operation="SafeAdd">0.05</MeditationFocusGain>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/MeditationFocusGain</xpath>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VRE_ExtremeMeditation"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<biostatCpx Operation="SafeReplace">2</biostatCpx>
							<biostatMet Operation="SafeReplace">-2</biostatMet>
							<statOffsets Operation="Safe">
								<MeditationFocusGain Operation="SafeAdd">0.1</MeditationFocusGain>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/MeditationFocusGain</xpath>
					</Operation>
				</apply>
			</Operation>

			<!-- 390 ranged -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VRE_SlowShooter"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Violence_Ranged</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">10</displayOrderInCategory>
							<statOffsets Operation="Safe">
								<RangedCooldownFactor Operation="SafeAdd">0.2</RangedCooldownFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/RangedCooldownFactor</xpath>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_FastShooter"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Violence_Ranged</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">20</displayOrderInCategory>
				</value>
			</Operation>

			<!-- 380 melee -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VRE_SlowMeleeHitter"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<MeleeCooldownFactor Operation="SafeAdd">0.2</MeleeCooldownFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/MeleeCooldownFactor</xpath>
					</Operation>
				</apply>
			</Operation>

			<!-- -10 skin -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_Leatherskin"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<ArmorRating_Sharp Operation="SafeReplace">0.30</ArmorRating_Sharp>
						<ArmorRating_Blunt Operation="SafeReplace">0.10</ArmorRating_Blunt>
					</statOffsets>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
