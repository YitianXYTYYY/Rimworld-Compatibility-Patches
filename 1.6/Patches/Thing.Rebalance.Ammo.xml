<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>reel.turretpipeline</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="ReelTurretAmmo"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef</xpath>
						<value>
							<stackLimit Operation="SafeReplace">150</stackLimit>
							<statBases Operation="Safe">
								<Flammability Operation="SafeReplace">0.6</Flammability>
								<MarketValue Operation="SafeReplace">3</MarketValue>
								<Mass Operation="SafeReplace">0.1</Mass>
							</statBases>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>mlie.yayoscombat3</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>ThingDef/thingCategories</xpath>
								<value>
									<li Operation="SafeAdd" Compare="InnerText">yy_ammo_category</li>
									<li Operation="SafeRemove" Compare="InnerText">Manufactured</li>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/RecipeDef[defName="Make_TurretAmmo"]</xpath>
				<value>
					<workAmount Operation="SafeReplace">900</workAmount>
					<ingredients Operation="SafeReplace">
						<li>
							<filter>
								<thingDefs>
									<li>Uranium</li>
								</thingDefs>
							</filter>
							<count>15</count>
						</li>
						<li>
							<filter>
								<thingDefs>
									<li>Steel</li>
								</thingDefs>
							</filter>
							<count>30</count>
						</li>
					</ingredients>
					<products Operation="Safe">
						<ReelTurretAmmo Operation="SafeReplace">50</ReelTurretAmmo>
					</products>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/RecipeDef[defName="Make_TurretAmmoBulk"]</xpath>
			</Operation>
		</caseTrue>
	</Operation>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>mlie.yayoscombat3</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingCategoryDef[defName="yy_ammo_category"]</xpath>
				<value>
					<label Operation="SafeReplace">ammunition</label>
					<parent Operation="SafeReplace">Manufactured</parent>
				</value>
			</Operation>
			<!-- Ammo -->
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/ThingDef[defName="yy_ammo_primitive" or 
					defName="yy_ammo_primitive_fire" or 
					defName="yy_ammo_primitive_emp" or 
					defName="yy_ammo_industrial" or 
					defName="yy_ammo_industrial_fire" or 
					defName="yy_ammo_industrial_emp" or 
					defName="yy_ammo_spacer" or 
					defName="yy_ammo_spacer_fire" or 
					defName="yy_ammo_spacer_emp"]</xpath>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>syrus.yayoscombataddon</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>Defs/ThingDef[defName="yy_ammo_primitive_light" or 
							defName="yy_ammo_primitive_heavy" or 
							defName="yy_ammo_industrial_light" or 
							defName="yy_ammo_industrial_heavy" or 
							defName="yy_ammo_spacer_light" or 
							defName="yy_ammo_spacer_heavy"]</xpath>
					</Operation>
				</caseTrue>
			</Operation>
			<!-- Ammo Trade -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/TraderKindDef[defName="Base_Neolithic_Standard" or 
					defName="Caravan_Neolithic_WarMerchant" or 
					defName="Visitor_Neolithic_Standard"]/stockGenerators</xpath>
				<value>
					<li Class="StockGenerator_SingleDef" Operation="Add">
						<thingDef>AmmoPrimitive</thingDef>
						<countRange>45~225</countRange>
					</li>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/TraderKindDef[defName="Base_Outlander_Standard" or 
					defName="Caravan_Outlander_CombatSupplier" or 
					defName="Orbital_CombatSupplier" or 
					defName="Orbital_PirateMerchant" or 
					defName="Visitor_Outlander_Standard"]/stockGenerators</xpath>
				<value>
					<li Class="StockGenerator_SingleDef" Operation="Add">
						<thingDef>AmmoIndustrial</thingDef>
						<countRange>45~450</countRange>
					</li>
					<li Class="StockGenerator_Category" Operation="Add">
						<categoryDef>yy_ammo_category</categoryDef>
						<thingDefCountRange>1~3</thingDefCountRange>
						<totalPriceRange>15~150</totalPriceRange>
						<excludedThingDefs>
							<li>AmmoPrimitive</li>
							<li>AmmoIndustrial</li>
						</excludedThingDefs>
					</li>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>ludeon.rimworld.biotech</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/TraderKindDef[defName="Base_Empire_Standard" or 
							defName="Empire_Caravan_TraderGeneral" or 
							defName="Orbital_Empire"]/stockGenerators</xpath>
						<value>
							<li Class="StockGenerator_SingleDef" Operation="Add">
								<thingDef>AmmoIndustrial</thingDef>
								<countRange>30~300</countRange>
							</li>
							<li Class="StockGenerator_SingleDef" Operation="Add">
								<thingDef>AmmoSpacer</thingDef>
								<countRange>30~300</countRange>
							</li>
							<li Class="StockGenerator_Category" Operation="Add">
								<categoryDef>yy_ammo_category</categoryDef>
								<thingDefCountRange>2~3</thingDefCountRange>
								<totalPriceRange>15~150</totalPriceRange>
								<excludedThingDefs>
									<li>AmmoPrimitive</li>
									<li>AmmoIndustrial</li>
									<li>AmmoSpacer</li>
								</excludedThingDefs>
							</li>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>Teiwaz.GTGOT</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/TraderKindDef[defName="Orbital_GTGMilitary"]/stockGenerators</xpath>
						<value>
							<li Class="StockGenerator_SingleDef" Operation="Add">
								<thingDef>AmmoIndustrial</thingDef>
								<countRange>150~600</countRange>
							</li>
							<li Class="StockGenerator_SingleDef" Operation="Add">
								<thingDef>AmmoSpacer</thingDef>
								<countRange>75~450</countRange>
							</li>
							<li Class="StockGenerator_Category" Operation="Add">
								<categoryDef>yy_ammo_category</categoryDef>
								<thingDefCountRange>2~4</thingDefCountRange>
								<totalPriceRange>30~300</totalPriceRange>
								<excludedThingDefs>
									<li>AmmoPrimitive</li>
									<li>AmmoIndustrial</li>
									<li>AmmoSpacer</li>
								</excludedThingDefs>
							</li>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/TraderKindDef[defName="Orbital_GTGBlackMarket"]/stockGenerators</xpath>
						<value>
							<li Class="StockGenerator_SingleDef" Operation="Add">
								<thingDef>AmmoIndustrial</thingDef>
								<countRange>30~300</countRange>
							</li>
							<li Class="StockGenerator_Category" Operation="Add">
								<categoryDef>yy_ammo_category</categoryDef>
								<thingDefCountRange>2~4</thingDefCountRange>
								<totalPriceRange>15~150</totalPriceRange>
								<excludedThingDefs>
									<li>AmmoPrimitive</li>
									<li>AmmoIndustrial</li>
								</excludedThingDefs>
							</li>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
