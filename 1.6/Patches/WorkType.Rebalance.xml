<?xml version="1.0" encoding="utf-8"?>
<Patch>	

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Meditate As WorkType (Continued)</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/WorkTypeDef[defName="MeditateForPsyfocus"]/labelShort</xpath>
					<value>
						<labelShort>Meditate</labelShort>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/WorkGiverDef[defName="MeditateAnima"]/workType</xpath>
					<value>
						<workType>MeditateForPsyfocus</workType>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Genetics Expanded</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/WorkGiverDef[defName="CreateXenogerm"]/workType</xpath>
					<value>
						<workType>GR_Genetics</workType>
					</value>
				</li>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Gene Fabrication</li>
					</mods>
					<match Class="PatchOperationReplace">
						<xpath>Defs/WorkGiverDef[defName="GeneFab_DoBillsGeneBench"]/workType</xpath>
						<value>
							<workType>GR_Genetics</workType>
						</value>
					</match>
				</li>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Genepack Reprocessor</li>
					</mods>
					<match Class="PatchOperationReplace">
						<xpath>Defs/WorkGiverDef[defName="SeparateGenepack"]/workType</xpath>
						<value>
							<workType>GR_Genetics</workType>
						</value>
					</match>
				</li>
			</operations>
		</match>
	</Operation>

</Patch>
