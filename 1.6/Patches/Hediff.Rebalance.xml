<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- psylink -->
	<Operation Class="XmlExtensions.SetScope">
		<xpath>Defs/HediffDef[defName="PsychicAmplifier"]</xpath>
		<apply>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li/statFactors</xpath>
				<value>
					<PsychicEntropyMax Operation="SafeRemove"/>
					<PsychicEntropyRecoveryRate Operation="SafeRemove"/>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="2"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">10</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.06</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="3"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">20</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.12</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="4"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">30</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.18</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="5"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">40</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.24</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>HediffDef/stages/li[minSeverity="6"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicEntropyMax Operation="SafeAdd">50</PsychicEntropyMax>
						<PsychicEntropyRecoveryRate Operation="SafeAdd">0.30</PsychicEntropyRecoveryRate>
					</statOffsets>
				</value>
			</Operation>
		</apply>
	</Operation>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>ludeon.rimworld.royalty</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- prosthetics -->
			<!-- archotech -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="PsychicSensitizer"]/stages/li</xpath>
				<value>
					<statOffsets Operation="Safe">
						<PsychicSensitivity Operation="SafeReplace">0.4</PsychicSensitivity>
					</statOffsets>
				</value>
			</Operation>
			<!-- bionic -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="Immunoenhancer"]/stages/li</xpath>
				<value>
					<statOffsets Operation="Safe">
						<ImmunityGainSpeed Operation="SafeReplace">0.1</ImmunityGainSpeed>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="HealingEnhancer"]/stages/li</xpath>
				<value>
					<naturalHealingFactor Operation="SafeRemove"/>
					<statFactors Operation="Safe">
						<InjuryHealingFactor Operation="SafeRemove">0</InjuryHealingFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<InjuryHealingFactor Operation="SafeAdd">1</InjuryHealingFactor>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="ToughskinGland"]/stages/li</xpath>
				<value>
					<capMods Operation="Safe">
						<li Operation="Safe" Compare="InnerText" XPathLocal="capacity">
							<capacity Operation="Safe">Moving</capacity>
							<offset Operation="SafeAdd">-0.1</offset>
							<postFactor Operation="SafeRemove">0</postFactor>
						</li>
					</capMods>
					<statOffsets Operation="Safe">
						<ArmorRating_Sharp Operation="SafeReplace">0.4</ArmorRating_Sharp>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="ArmorskinGland"]/stages/li</xpath>
				<value>
					<capMods Operation="Safe">
						<li Operation="Safe" Compare="InnerText" XPathLocal="capacity">
							<capacity Operation="Safe">Moving</capacity>
							<offset Operation="SafeAdd">-0.15</offset>
							<postFactor Operation="SafeRemove">0</postFactor>
						</li>
					</capMods>
					<statOffsets Operation="Safe">
						<ArmorRating_Sharp Operation="SafeReplace">0.5</ArmorRating_Sharp>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="StoneskinGland"]/stages/li</xpath>
				<value>
					<capMods Operation="Safe">
						<li Operation="Safe" Compare="InnerText" XPathLocal="capacity">
							<capacity Operation="Safe">Moving</capacity>
							<offset Operation="SafeAdd">-0.2</offset>
							<postFactor Operation="SafeRemove">0</postFactor>
						</li>
					</capMods>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="ReprocessorStomach"]/stages/li</xpath>
				<value>
					<hungerRateFactor Operation="SafeReplace">0.8</hungerRateFactor>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="NuclearStomach"]/stages/li</xpath>
				<value>
					<hungerRateFactor Operation="SafeReplace">0.2</hungerRateFactor>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="CircadianAssistant"]/stages/li</xpath>
				<value>
					<statFactors Operation="Safe">
						<RestFallRateFactor Operation="SafeAdd">0.8</RestFallRateFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<RestFallRateFactor Operation="SafeRemove">0</RestFallRateFactor>
					</statOffsets>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>ludeon.rimworld.biotech</li>
