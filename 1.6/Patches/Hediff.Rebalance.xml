<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>ludeon.rimworld.royalty</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="Immunoenhancer"]/stages/li</xpath>
				<value>
					<statOffsets Operation="Safe">
						<ImmunityGainSpeed Operation="SafeReplace">0.1</ImmunityGainSpeed>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="HealingEnhancer"]/stages/li</xpath>
				<value>
					<statOffsets Operation="Safe">
						<InjuryHealingFactor Operation="SafeAdd">1</InjuryHealingFactor>
					</statOffsets>
					<naturalHealingFactor Operation="SafeRemove"/>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="ToughskinGland"]/stages/li</xpath>
				<value>
					<capMods Operation="Safe">
						<li Operation="Safe" Compare="InnerText" XPathLocal="capacity">
							<capacity Operation="Safe">Moving</capacity>
							<offset Operation="SafeAdd">-0.1</offset>
							<postFactor Operation="SafeRemove">0</postFactor>
						</li>
					</capMods>
					<statOffsets Operation="Safe">
						<ArmorRating_Sharp Operation="SafeReplace">0.4</ArmorRating_Sharp>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="ArmorskinGland"]/stages/li</xpath>
				<value>
					<capMods Operation="Safe">
						<li Operation="Safe" Compare="InnerText" XPathLocal="capacity">
							<capacity Operation="Safe">Moving</capacity>
							<offset Operation="SafeAdd">-0.15</offset>
							<postFactor Operation="SafeRemove">0</postFactor>
						</li>
					</capMods>
					<statOffsets Operation="Safe">
						<ArmorRating_Sharp Operation="SafeReplace">0.5</ArmorRating_Sharp>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="StoneskinGland"]/stages/li</xpath>
				<value>
					<capMods Operation="Safe">
						<li Operation="Safe" Compare="InnerText" XPathLocal="capacity">
							<capacity Operation="Safe">Moving</capacity>
							<offset Operation="SafeAdd">-0.2</offset>
							<postFactor Operation="SafeRemove">0</postFactor>
						</li>
					</capMods>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="ReprocessorStomach"]/stages/li</xpath>
				<value>
					<hungerRateFactor Operation="SafeReplace">0.8</hungerRateFactor>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="NuclearStomach"]/stages/li</xpath>
				<value>
					<hungerRateFactor Operation="SafeReplace">0.2</hungerRateFactor>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="CircadianAssistant"]/stages/li</xpath>
				<value>
					<statFactors Operation="Safe">
						<RestFallRateFactor Operation="SafeAdd">0.8</RestFallRateFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<RestFallRateFactor Operation="SafeRemove">0</RestFallRateFactor>
					</statOffsets>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>mse2.core</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/HediffDef/comps/li[@Class="MSE2.HediffCompProperties_ModuleHolder" and maxModules="1"]</xpath>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeReplace">
				<xpath>Defs/HediffDef/comps/li[@Class="MSE2.HediffCompProperties_ModuleHolder" and maxModules="2"]</xpath>
				<value>
					<maxModules>1</maxModules>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
