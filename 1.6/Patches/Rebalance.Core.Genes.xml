<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/GeneDef[defName="WoundHealing_Fast" or defName="WoundHealing_SuperFast"]/statFactors/InjuryHealingFactor</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/GeneDef[defName="WoundHealing_Fast"]</xpath>
		<value>
			<statOffsets>
				<InjuryHealingFactor>1</InjuryHealingFactor>
			</statOffsets>
		</value>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/GeneDef[defName="WoundHealing_SuperFast"]</xpath>
		<value>
			<statOffsets>
				<InjuryHealingFactor>3</InjuryHealingFactor>
			</statOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/GeneDef[defName="MeleeDamage_Strong"]/statFactors/MeleeDamageFactor</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/GeneDef[defName="MeleeDamage_Strong"]</xpath>
		<value>
			<statOffsets>
				<MeleeDamageFactor>0.5</MeleeDamageFactor>
			</statOffsets>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[defName="Hands_Pig"]/capMods</xpath>
		<value>
			<capMods>
				<li>
					<capacity>Manipulation</capacity>
					<offset>-0.15</offset>
				</li>
			</capMods>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[defName="ElongatedFingers"]/capMods</xpath>
		<value>
			<capMods>
				<li>
					<capacity>Manipulation</capacity>
					<offset>0.1</offset>
				</li>
			</capMods>
		</value>
	</Operation>

</Patch>
