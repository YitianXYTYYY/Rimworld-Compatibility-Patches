<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.SetScope">
		<xpath>Defs/ReplaceLib.ReplacerDef[defName="ReplaceLib_XYTYYY"]</xpath>
		<apply>
			<!-- Vanilla Factions Expanded - Insectoids 2 -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>oskarpotocki.vfe.insectoid2</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>com.abobashark.zoologymod</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="PatchOperationAdd">
								<xpath>ReplaceLib.ReplacerDef/replacers</xpath>
								<value>
									<li>
										<replace>Leather_Chitin</replace>
										<with>VFEI2_Chitin</with>
									</li>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</caseTrue>
			</Operation>
			<!-- Yayo's Combat 3 (Continued) -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>mlie.yayoscombat3</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="PatchOperationAdd">
						<xpath>ReplaceLib.ReplacerDef/replacers</xpath>
						<value>
							<li>
								<replace>yy_ammo_primitive</replace>
								<with>AmmoPrimitive</with>
							</li>
							<li>
								<replace>yy_ammo_primitive_fire</replace>
								<with>AmmoPrimitive</with>
							</li>
							<li>
								<replace>yy_ammo_primitive_emp</replace>
								<with>AmmoPrimitive</with>
							</li>
							<li>
								<replace>yy_ammo_industrial</replace>
								<with>AmmoIndustrial</with>
							</li>
							<li>
								<replace>yy_ammo_industrial_fire</replace>
								<with>AmmoIndustrial</with>
							</li>
							<li>
								<replace>yy_ammo_industrial_emp</replace>
								<with>AmmoIndustrial</with>
							</li>
							<li>
								<replace>yy_ammo_spacer</replace>
								<with>AmmoSpacer</with>
							</li>
							<li>
								<replace>yy_ammo_spacer_fire</replace>
								<with>AmmoSpacerEMP</with>
							</li>
							<li>
								<replace>yy_ammo_spacer_emp</replace>
								<with>AmmoSpacerEMP</with>
							</li>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>syrus.yayoscombataddon</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="PatchOperationAdd">
								<xpath>ReplaceLib.ReplacerDef/replacers</xpath>
								<value>
									<li>
										<replace>yy_ammo_primitive_light</replace>
										<with>AmmoPrimitive</with>
									</li>
									<li>
										<replace>yy_ammo_primitive_heavy</replace>
										<with>AmmoPrimitive</with>
									</li>
									<li>
										<replace>yy_ammo_industrial_light</replace>
										<with>AmmoIndustrial</with>
									</li>
									<li>
										<replace>yy_ammo_industrial_heavy</replace>
										<with>AmmoIndustrial</with>
									</li>
									<li>
										<replace>yy_ammo_spacer_light</replace>
										<with>AmmoSpacer</with>
									</li>
									<li>
										<replace>yy_ammo_spacer_heavy</replace>
										<with>AmmoSpacer</with>
									</li>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</caseTrue>
			</Operation>
		</apply>
	</Operation>

</Patch>