<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.SetScope">
		<xpath>Defs/ReplaceLib.ReplacerDef[defName="ReplaceLib_XYTYYY"]</xpath>
		<apply>
			<!-- ReSplice: Core -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>resplice.xotr.core</li>
				</mods>
				<packageId>true</packageId>
				<logic>and</logic>
				<caseTrue>
					<!-- Genepack Reprocessor -->
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>Anonemous2.GenepackReprocessor</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="PatchOperationAdd">
								<xpath>ReplaceLib.ReplacerDef/replacers</xpath>
								<value>
									<li>
										<replace>RS_GeneCentrifuge</replace>
										<with>GeneSeparator</with>
									</li>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</caseTrue>
			</Operation>
			<!-- Vanilla Factions Expanded - Insectoids 2 -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>oskarpotocki.vfe.insectoid2</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>com.abobashark.zoologymod</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="PatchOperationAdd">
								<xpath>ReplaceLib.ReplacerDef/replacers</xpath>
								<value>
									<li>
										<replace>Leather_Chitin</replace>
										<with>VFEI2_Chitin</with>
									</li>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</caseTrue>
			</Operation>
		</apply>
	</Operation>

</Patch>