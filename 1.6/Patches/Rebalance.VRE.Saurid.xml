<?xml version="1.0" encoding="utf-8"?>
<Patch>	

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Saurid</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[defName="VRESaurids_ScaleSkin"]/biostatMet</xpath>
					<value>
						<biostatMet>-2</biostatMet>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[defName="VRESaurids_ScaleSkin"]/statOffsets</xpath>
					<value>
						<statOffsets>
							<ArmorRating_Sharp>0.4</ArmorRating_Sharp>
						</statOffsets>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[defName="VRESaurids_SauridClaws"]/capMods</xpath>
					<value>
						<capMods>
							<li>
								<capacity>Manipulation</capacity>
								<offset>-0.05</offset>
							</li>
						</capMods>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

</Patch>
