<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- 550 aging -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.pigskin</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.pigskin</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_RapidAging"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Health_Age</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">0</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_FastAging"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Health_Age</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">10</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_SlowAging"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Health_Age</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">20</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>vanillaracesexpanded.archon</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>Defs/GeneDef[defName="VRE_EarlyMaturity"]</xpath>
								<value>
									<displayCategory Operation="AddOrReplace">Health_Age</displayCategory>
									<displayOrderInCategory Operation="AddOrReplace">100</displayOrderInCategory>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_EverGrowing"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Health_Age</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">200</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>vanillaracesexpanded.phytokin</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>Defs/GeneDef[defName="VRE_ProgressiveAttunement"]</xpath>
								<value>
									<displayCategory Operation="AddOrReplace">Health_Age</displayCategory>
									<displayOrderInCategory Operation="AddOrReplace">1000</displayOrderInCategory>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- 540 meat -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.pigskin</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VRE_LowMeat"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<biostatCpx Operation="SafeReplace">1</biostatCpx>
							<displayCategory Operation="AddOrReplace">MeatLeather</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">-100</displayOrderInCategory>
							<statOffsets Operation="Safe">
								<MeatAmount Operation="SafeAdd">-70</MeatAmount>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/MeatAmount</xpath>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VRE_ExtraMeat"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<biostatCpx Operation="SafeReplace">1</biostatCpx>
							<displayCategory Operation="AddOrReplace">MeatLeather</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">-90</displayOrderInCategory>
							<statOffsets Operation="Safe">
								<MeatAmount Operation="SafeAdd">70</MeatAmount>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/MeatAmount</xpath>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.fungoid</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_FungalFlesh"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">MeatLeather</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">90</displayOrderInCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.fungoid</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_FungalFlesh"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">MeatLeather</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">100</displayOrderInCategory>
							<exclusionTags Operation="Safe">
								<li Operation="SafeAdd" Compare="InnerText">Flesh</li>
								<li Operation="SafeAdd" Compare="InnerText">Meat</li>
								<li Operation="SafeAdd" Compare="InnerText">AG_Meat</li>
							</exclusionTags>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.insector</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_InsectFlesh"]</xpath>
						<value>
							<biostatCpx Operation="SafeReplace">1</biostatCpx>
							<displayCategory Operation="AddOrReplace">MeatLeather</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">110</displayOrderInCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_PorkFlesh"]</xpath>
				<value>
					<biostatCpx Operation="SafeReplace">1</biostatCpx>
					<displayCategory Operation="AddOrReplace">MeatLeather</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">120</displayOrderInCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_PigSkin"]</xpath>
				<value>
					<biostatCpx Operation="SafeReplace">1</biostatCpx>
					<displayCategory Operation="AddOrReplace">MeatLeather</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">1000</displayOrderInCategory>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- 310 mental -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.pigskin</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_Coward"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Mood_Mental</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">0</displayOrderInCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_Brave"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Mood_Mental</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">10</displayOrderInCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.hussar</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VREH_Dutiful"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Mood_Mental</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">100</displayOrderInCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.lycanthrope</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_Territorial"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Mood_Mental</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">200</displayOrderInCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
