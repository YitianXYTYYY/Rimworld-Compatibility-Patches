<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>Ludeon.RimWorld.Biotech</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="Immunity_Strong"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/ImmunityGainSpeed</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<ImmunityGainSpeed Operation="SafeAdd">0.10</ImmunityGainSpeed>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="Immunity_SuperStrong"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/ImmunityGainSpeed</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<ImmunityGainSpeed Operation="SafeAdd">0.50</ImmunityGainSpeed>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="WoundHealing_Fast"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/InjuryHealingFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="SafeAdd">1</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="WoundHealing_SuperFast"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/InjuryHealingFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="SafeAdd">3</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="PsychicBond"]</xpath>
				<apply>	<Operation Class="PatchOperationReplace">
					<xpath>HediffDef/stages/li[minSeverity="0"]/statOffsets/PsychicSensitivity</xpath>
					<value>
						<PsychicSensitivity>0.2</PsychicSensitivity>
					</value>
				</Operation>
				<Operation Class="XmlExtensions.PatchOperationSafeReplace">
					<xpath>HediffDef/stages/li[minSeverity="0"]/capMods/li[capacity="Consciousness"]/offset</xpath>
					<value>
						<offset>0.1</offset>
					</value>
				</Operation>
				<Operation Class="XmlExtensions.PatchOperationSafeReplace">
					<xpath>HediffDef/stages/li[minSeverity="1"]/statOffsets/PsychicSensitivity</xpath>
					<value>
						<PsychicSensitivity>0.1</PsychicSensitivity>
					</value>
				</Operation>
				<Operation Class="XmlExtensions.PatchOperationSafeReplace">
					<xpath>HediffDef/stages/li[minSeverity="1"]/capMods/li[capacity="Consciousness"]/offset</xpath>
					<value>
						<offset>-0.2</offset>
					</value>
				</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VerySleepy"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/RestFallRateFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<RestFallRateFactor Operation="SafeAdd">0.8</RestFallRateFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="Sleepy"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/RestFallRateFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<RestFallRateFactor Operation="SafeAdd">0.4</RestFallRateFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="Nearsighted"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<ShootingAccuracyFactor_Long Operation="SafeReplace">0.3</ShootingAccuracyFactor_Long>
						<ShootingAccuracyFactor_Medium Operation="SafeReplace">0.6</ShootingAccuracyFactor_Medium>
					</statFactors>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/GeneDef[defName="ViolenceDisabled"]/exclusionTags/li[text()="ShootingAccuracy"]</xpath>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="MeleeDamage_Strong"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/MeleeDamageFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<MeleeDamageFactor Operation="SafeAdd">0.5</MeleeDamageFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="Robust"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<IncomingDamageFactor Operation="SafeReplace">0.8</IncomingDamageFactor>
					</statFactors>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="Hands_Pig"]/capMods/li[capacity="Manipulation"]</xpath>
				<value>
					<postFactor Operation="SafeRemove"/>
					<offset Operation="SafeAdd">-0.15</offset>
				</value>
			</Operation>
	
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="ElongatedFingers"]/capMods/li[capacity="Manipulation"]</xpath>
				<value>
					<postFactor Operation="SafeRemove"/>
					<offset Operation="SafeAdd">0.1</offset>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
