<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>seohyeon.optimizationmeats</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>com.abobashark.zoologymod</li>
					<li>VanillaExpanded.VAEWaste</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="PatchOperationAdd">
						<xpath>/Defs/AlienMeatTest.MeatListDef[defName="WhiteList"]/meats</xpath>
						<value>
							<li>ToxicMeat</li>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
