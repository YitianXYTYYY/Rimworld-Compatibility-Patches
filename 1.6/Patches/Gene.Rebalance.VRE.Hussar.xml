<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.fungoid</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- weapon aptitude -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>hussars.blablabla.cantbearsedtocomeupwithafunnyid</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.SetScope">
						<xpath>Defs/GeneDef[defName="SEX_RangedWeaponAptitude"]</xpath>
						<apply>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>GeneDef</xpath>
								<value>
									<displayCategory Operation="AddOrReplace">Violence_Ranged</displayCategory>
									<displayOrderInCategory Operation="AddOrReplace">-100</displayOrderInCategory>
									<exclusionTags Operation="Safe">
										<li Operation="SafeAdd" Compare="InnerText">SEX_WeaponAptitude</li>
									</exclusionTags>
									<statOffsets Operation="Safe">
										<ShootingAccuracyPawn Operation="SafeAdd">12</ShootingAccuracyPawn>
									</statOffsets>
								</value>
							</Operation>
							<Operation Class="XmlExtensions.PatchOperationSafeRemove">
								<xpath>GeneDef/statFactors/ShootingAccuracyPawn</xpath>
							</Operation>
						</apply>
					</Operation>
					<Operation Class="XmlExtensions.SetScope">
						<xpath>Defs/GeneDef[defName="SEX_MeleeWeaponAptitude"]</xpath>
						<apply>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>GeneDef</xpath>
								<value>
									<displayCategory Operation="AddOrReplace">Violence_Melee</displayCategory>
									<displayOrderInCategory Operation="AddOrReplace">-100</displayOrderInCategory>
									<exclusionTags Operation="Safe">
										<li Operation="SafeAdd" Compare="InnerText">SEX_WeaponAptitude</li>
									</exclusionTags>
									<statOffsets Operation="Safe">
										<MeleeHitChance Operation="SafeAdd">12</MeleeHitChance>
									</statOffsets>
								</value>
							</Operation>
							<Operation Class="XmlExtensions.PatchOperationSafeRemove">
								<xpath>GeneDef/statFactors/MeleeHitChance</xpath>
							</Operation>
						</apply>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- 0 misc -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VREH_Giant"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<VEF_BodySize_Multiplier Operation="SafeAdd">0.1</VEF_BodySize_Multiplier>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/VEF_BodySize_Multiplier</xpath>
					</Operation>
				</apply>
			</Operation>

			<!-- -220 wing -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.hussar</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VREH_Glidewings"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Cosmetic_Body_Wing</displayCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

		</caseTrue>
	</Operation>

</Patch>
