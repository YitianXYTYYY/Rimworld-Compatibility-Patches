<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Reload (Continued)</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Reload.Defs.ReloadPresetDef[defName="VWE_Bow_Compound"]/ammoDef</xpath>
					<value>
						<ammoDef>R_Ammo_Primitive</ammoDef>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Reload.Defs.ReloadPresetDef[defName="VWE_Gun_ChargeMinigun"]/magazineCapacity</xpath>
					<value>
						<magazineCapacity>180</magazineCapacity>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Reload.Defs.ReloadPresetDef[ammoDef="R_Ammo_Primitive"]/reloadTicks</xpath>
					<value>
						<reloadTicks>24</reloadTicks>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/Reload.Defs.ReloadPresetDef[ammoDef="R_Ammo_Primitive_Explosive"]/reloadTicks</xpath>
					<value>
						<reloadTicks>54</reloadTicks>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

</Patch>
