<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>zal.reload</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- presets -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/Reload.Defs.ReloadPresetDef[defName="Flamebow" or 
					defName="UncompromisingTribalFaction_GreatFlamebow" or 
					defName="VWE_Bow_Compound"]</xpath>
				<value>
					<ammoDef Operation="SafeReplace">R_Ammo_Primitive</ammoDef>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/Reload.Defs.ReloadPresetDef[defName="Weapon_GrenadeMolotov"]</xpath>
				<value>
					<ammoDef Operation="SafeReplace">R_Ammo_Primitive_Explosive</ammoDef>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
					<xpath>Defs/Reload.Defs.ReloadPresetDef[ammoDef="R_Ammo_Primitive"]</xpath>
				<value>
					<reloadTicks Operation="SafeReplace">30</reloadTicks>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/Reload.Defs.ReloadPresetDef[defName="Gun_SmokeLauncher" or 
					defName="Weapon_GrenadeTox" or 
					defName="VWE_SmokeGrenade"]</xpath>
				<value>
					<ammoDef Operation="SafeReplace">R_Ammo_Industrial_Special</ammoDef>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
					<xpath>Defs/Reload.Defs.ReloadPresetDef[ammoDef="Gun_Minigun"]</xpath>
				<value>
					<magazineCapacity Operation="SafeReplace">150</magazineCapacity>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
					<xpath>Defs/Reload.Defs.ReloadPresetDef[ammoDef="VWE_Gun_ChargeMinigun"]</xpath>
				<value>
					<magazineCapacity Operation="SafeReplace">120</magazineCapacity>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
