<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.insector</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- 540 meat -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_InsectFlesh"]</xpath>
				<value>
					<biostatCpx Operation="SafeReplace">1</biostatCpx>
				</value>
			</Operation>

			<!-- 530 blood -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_BugBlood"]</xpath>
				<value>
					<biostatCpx Operation="SafeReplace">0</biostatCpx>
				</value>
			</Operation>

			<!-- -70 skin -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_InsectSkin"]</xpath>
				<value>
					<biostatCpx Operation="SafeReplace">1</biostatCpx>
					<statOffsets Operation="Safe">
						<ArmorRating_Sharp Operation="SafeReplace">0.20</ArmorRating_Sharp>
						<ArmorRating_Blunt Operation="SafeReplace">0.20</ArmorRating_Blunt>
					</statOffsets>
				</value>
			</Operation>

			<!-- -130 headbone -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_InsectAntennae"]</xpath>
				<value>
					<biostatCpx Operation="SafeReplace">0</biostatCpx>
					<displayCategory Operation="AddOrReplace">Cosmetic_Headbone</displayCategory>
					<exclusionTags Operation="Safe">
						<li Operation="SafeAdd" Compare="InnerText">Headbone</li>
					</exclusionTags>
					<iconColor Operation="SafeAdd">(0.75, 0.75, 0.75)</iconColor>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
