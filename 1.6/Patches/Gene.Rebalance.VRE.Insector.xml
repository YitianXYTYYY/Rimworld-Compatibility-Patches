<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.insector</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- evolutions -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_CompoundEyes"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<VEF_VerbRangeFactor Operation="SafeRemove">0</VEF_VerbRangeFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<ShootingAccuracyPawn Operation="SafeReplace">4</ShootingAccuracyPawn>
						<VEF_VerbRangeFactor Operation="SafeAdd">0.1</VEF_VerbRangeFactor>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_AntimicrobialPeptides"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<ImmunityGainSpeed Operation="SafeRemove">0</ImmunityGainSpeed>
						<InjuryHealingFactor Operation="SafeRemove">0</InjuryHealingFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<ImmunityGainSpeed Operation="SafeAdd">0.5</ImmunityGainSpeed>
						<InjuryHealingFactor Operation="SafeAdd">1</InjuryHealingFactor>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_InsectMandibles"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<EatingSpeed Operation="SafeRemove">0</EatingSpeed>
					</statFactors>
					<statOffsets Operation="Safe">
						<EatingSpeed Operation="SafeAdd">3</EatingSpeed>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_RobustMidgut"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<RawNutritionFactor Operation="SafeRemove">0</RawNutritionFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<RawNutritionFactor Operation="SafeAdd">0.8</RawNutritionFactor>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_HighGreyMatter"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<GlobalLearningFactor Operation="SafeRemove">0</GlobalLearningFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<GlobalLearningFactor Operation="SafeAdd">0.5</GlobalLearningFactor>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_HardenedChitin"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<IncomingDamageFactor Operation="SafeReplace">0.8</IncomingDamageFactor>
					</statFactors>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_SensitiveBrainGoop"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>VanillaRacesExpandedInsector.GenelineGeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<PsychicSensitivity Operation="SafeReplace">0.4</PsychicSensitivity>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.OptionalPatch">
						<modId>FrozenSnowFox.FrozenSnowFoxTweaks</modId>
						<key>FSFPsychicSensBonuses</key>
						<defaultValue>false</defaultValue>
						<caseTrue>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>VanillaRacesExpandedInsector.GenelineGeneDef/statOffsets</xpath>
								<value>
									<MeditationFocusGain Operation="SafeRemove"/>
									<PsychicEntropyRecoveryRate Operation="SafeRemove"/>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_RipperBlades"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<WorkSpeedGlobal Operation="SafeAdd">0.8</WorkSpeedGlobal>
					</statFactors>
					<statOffsets Operation="Safe">
						<WorkSpeedGlobal Operation="SafeRemove">0</WorkSpeedGlobal>
					</statOffsets>
				</value>
			</Operation>
			<!-- mutations -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_LowGreyMatter"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<GlobalLearningFactor Operation="SafeReplace">0.5</GlobalLearningFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<PsychicSensitivity Operation="SafeReplace">-0.4</PsychicSensitivity>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_RapidLifeCycle"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<LifespanFactor Operation="SafeReplace">0.4</LifespanFactor>
					</statFactors>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_WeakenedChitin"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<IncomingDamageFactor Operation="SafeRemove">0</IncomingDamageFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<IncomingDamageFactor Operation="SafeReplace">0.5</IncomingDamageFactor>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_Dormant"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<RestFallRateFactor Operation="SafeRemove">0</RestFallRateFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<RestFallRateFactor Operation="SafeReplace">0.8</RestFallRateFactor>
					</statOffsets>
				</value>
			</Operation>
		</caseTrue>
		<Operation Class="XmlExtensions.HybridPatch">
			<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_Stenothermic"]</xpath>
			<value>
				<statOffsets Operation="Safe">
					<ComfyTemperatureMin Operation="SafeReplace">5</ComfyTemperatureMin>
					<ComfyTemperatureMax Operation="SafeReplace">-5</ComfyTemperatureMax>
				</statOffsets>
			</value>
		</Operation>

		<Operation Class="XmlExtensions.FindMod">
			<mods>
				<li>oskarpotocki.vfe.insectoid2</li>
			</mods>
			<packageId>true</packageId>
			<caseTrue>
				<!-- evolutions -->
				<Operation Class="XmlExtensions.HybridPatch">
					<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_InsectRostrum"]</xpath>
					<value>
						<statFactors Operation="Safe">
							<EatingSpeed Operation="SafeRemove">0</EatingSpeed>
						</statFactors>
						<statOffsets Operation="Safe">
							<EatingSpeed Operation="SafeAdd">3</EatingSpeed>
						</statOffsets>
					</value>
				</Operation>
				<Operation Class="XmlExtensions.HybridPatch">
					<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_InfraredSensors"]</xpath>
					<value>
						<statFactors Operation="Safe">
							<ShootingAccuracyFactor_Medium Operation="SafeRemove">0</ShootingAccuracyFactor_Medium>
							<ShootingAccuracyFactor_Long Operation="SafeRemove">0</ShootingAccuracyFactor_Long>
						</statFactors>
						<statOffsets Operation="Safe">
							<ShootingAccuracyFactor_Medium Operation="SafeAdd">0.1</ShootingAccuracyFactor_Medium>
							<ShootingAccuracyFactor_Long Operation="SafeAdd">0.1</ShootingAccuracyFactor_Long>
						</statOffsets>
					</value>
				</Operation>
				<!-- mutations -->
				<Operation Class="XmlExtensions.HybridPatch">
					<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_Microsized"]</xpath>
					<value>
						<statFactors Operation="Safe">
							<LeatherAmount Operation="SafeRemove">0</LeatherAmount>
							<MeatAmount Operation="SafeRemove">0</MeatAmount>
							<StaggerDurationFactor Operation="SafeRemove">0</StaggerDurationFactor>
							<VEF_FoodCapacityMultiplier Operation="SafeRemove">0</VEF_FoodCapacityMultiplier>
						</statFactors>
						<statOffsets Operation="Safe">
							<StaggerDurationFactor Operation="SafeAdd">1</StaggerDurationFactor>
							<VEF_BodySize_Offset Operation="SafeReplace">-0.4</VEF_BodySize_Offset>
						</statOffsets>
					</value>
				</Operation>
				<Operation Class="XmlExtensions.HybridPatch">
					<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_Colossal"]</xpath>
					<value>
						<statFactors Operation="Safe">
							<LeatherAmount Operation="SafeRemove">0</LeatherAmount>
							<MeatAmount Operation="SafeRemove">0</MeatAmount>
							<MeleeDodgeChance Operation="SafeReplace">0.2</MeleeDodgeChance>
							<VEF_FoodCapacityMultiplier Operation="SafeRemove">0</VEF_FoodCapacityMultiplier>
						</statFactors>
						<statOffsets Operation="Safe">
							<VEF_BodySize_Offset Operation="SafeReplace">0.6</VEF_BodySize_Offset>
						</statOffsets>
					</value>
				</Operation>
				<Operation Class="XmlExtensions.HybridPatch">
					<xpath>Defs/VanillaRacesExpandedInsector.GenelineGeneDef[defName="VRE_Pyrophiliac"]</xpath>
					<value>
						<statOffsets Operation="Safe">
							<ComfyTemperatureMin Operation="SafeReplace">5</ComfyTemperatureMin>
						</statOffsets>
					</value>
				</Operation>
			</caseTrue>
		</Operation>
	</Operation>

</Patch>
