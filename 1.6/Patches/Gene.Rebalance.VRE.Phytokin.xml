<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.phytokin</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_BarkSkin"]</xpath>
				<value>
					<biostatMet Operation="SafeReplace">-2</biostatMet>
					<statOffsets Operation="Safe">
						<ArmorRating_Blunt Operation="SafeReplace">0.40</ArmorRating_Blunt>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_Female"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Miscellaneous</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>RedMattis.BetterPrerequisites</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="PatchOperationAdd">
						<xpath>Defs/CherryPicker.DefList[defName="CherryPicker_XYTYYY"]/defs</xpath>
						<value>
							<li>GeneDef/VRE_Female</li>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/XenotypeDef[defName="VRE_Poluxkin" or defName="VRE_Gauranlenkin" or defName="VRE_Animakin"]/genes</xpath>
						<value>
							<li Operation="SafeRemove" Compare="InnerText">VRE_Female</li>
							<li Operation="AddOrReplace" Compare="InnerText">Body_FemaleOnly</li>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
