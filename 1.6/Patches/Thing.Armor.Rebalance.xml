<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Apparel_FlakVest" or defName="Apparel_FlakPants" or defName="Apparel_FlakJacket"]/equippedStatOffsets/MoveSpeed</xpath>
		<value>
			<MoveSpeed>-0.1</MoveSpeed>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[@Name="ApparelArmorPowerBase"]/equippedStatOffsets/MoveSpeed</xpath>
		<value>
			<MoveSpeed>-0.2</MoveSpeed>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Royalty">
		<xpath>Defs/ThingDef[defName="Apparel_Gunlink"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
		<value>
			<ShootingAccuracyPawn>4</ShootingAccuracyPawn>
		</value>
	</Operation>
	<Operation Class="PatchOperationRemove" MayRequire="Ludeon.RimWorld.Royalty">
		<xpath>Defs/ThingDef[defName="Apparel_Gunlink"]/apparel/bodyPartGroups/li[text()="UpperHead"]</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Royalty">
		<xpath>Defs/ThingDef[defName="Apparel_Gunlink"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Ears</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationRemove" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_AirwireHeadset"]/apparel/bodyPartGroups/li[text()="UpperHead"]</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_AirwireHeadset"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Ears</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationRemove" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_ArrayHeadset"]/apparel/bodyPartGroups/li[text()="UpperHead"]</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_ArrayHeadset"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Eyes</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationAttributeSet" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_IntegratorHeadset"]</xpath>
		<attribute>ParentName</attribute>
		<value>MechanitorHeadsetBase</value>
	</Operation>
	<Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_IntegratorHeadset"]/apparel</xpath>
		<value>
			<mechanitorApparel>true</mechanitorApparel>
		</value>
	</Operation>
	<Operation Class="PatchOperationRemove" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_IntegratorHeadset"]/equippedStatOffsets/VacuumResistance</xpath>
	</Operation>
	<Operation Class="PatchOperationRemove" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_IntegratorHeadset"]/apparel/bodyPartGroups/li[text()="UpperHead"]</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_IntegratorHeadset"]/apparel/bodyPartGroups</xpath>
		<value>
			<li>Ears</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_ArmorHelmetMechlordHelmet"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
		<value>
			<ShootingAccuracyPawn>-4</ShootingAccuracyPawn>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_ArmorHelmetMechlordHelmet"]/equippedStatOffsets/MeleeHitChance</xpath>
		<value>
			<MeleeHitChance>-1</MeleeHitChance>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_MechlordSuit"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
		<value>
			<ShootingAccuracyPawn>-4</ShootingAccuracyPawn>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[defName="Apparel_MechlordSuit"]/equippedStatOffsets/MeleeHitChance</xpath>
		<value>
			<MeleeHitChance>-1</MeleeHitChance>
		</value>
	</Operation>
	<Operation Class="PatchOperationRemove" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[@Name="Apparel_Bandolier"]/equippedStatOffsets/RangedCooldownFactor</xpath>
	</Operation>
	<Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Biotech">
		<xpath>Defs/ThingDef[@Name="Apparel_Bandolier"]</xpath>
		<value>
			<modExtensions>
				<li Class="VEF.Apparels.ApparelExtension">
					<equippedStatFactors>
						<RangedCooldownFactor>0.8</RangedCooldownFactor>
					</equippedStatFactors>
				</li>
			</modExtensions>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace" MayRequire="Ludeon.RimWorld.Odyssey">
		<xpath>Defs/ThingDef[defName="Apparel_Vacsuit" or defName="Apparel_VacsuitChildren"]/equippedStatOffsets/MoveSpeed</xpath>
		<value>
			<MoveSpeed>-1.2</MoveSpeed>
		</value>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Armour Expanded</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingCategoryDef[defName="VAE_BootsAndGloves"]/parent</xpath>
					<value>
        				<parent>ApparelArmor</parent>
					</value>
				</li>

				<!-- label -->
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_LightPlateArmor"]/label</xpath>
					<value>
						<label>plate light armor</label>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_Chestplate"]/label</xpath>
					<value>
						<label>plate chest</label>
					</value>
				</li>

				<!-- Medieval plate -->
				<li Class="PatchOperationAttributeSet">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_LightPlateArmor" or 
						defName="VAE_Apparel_PlateShoulderpads" or 
						defName="VAE_Apparel_Chestplate" or 
						defName="VAE_Apparel_Chainmail"]</xpath>
					<attribute>ParentName</attribute>
					<value>ArmorSmithableBase</value>
				</li>
				<li Class="PatchOperationAttributeSet">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_PlateHelmet"]</xpath>
					<attribute>ParentName</attribute>
					<value>ArmorHelmetMakeableBase</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_LightPlateArmor" or 
						defName="VAE_Apparel_PlateShoulderpads" or 
						defName="VAE_Apparel_Chestplate" or 
						defName="VAE_Apparel_Chainmail" or 
						defName="VAE_Apparel_PlateHelmet"]</xpath>
					<value>
						<thingSetMakerTags>
							<li>RewardStandardQualitySuper</li>
						</thingSetMakerTags>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_LightPlateArmor" or 
						defName="VAE_Apparel_PlateShoulderpads" or 
						defName="VAE_Apparel_Chestplate" or 
						defName="VAE_Apparel_Chainmail" or 
						defName="VAE_Apparel_PlateHelmet"]/tradeTags</xpath>
					<value>
						<li>Clothing</li>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_LightPlateArmor" or 
						defName="VAE_Apparel_PlateShoulderpads" or 
						defName="VAE_Apparel_Chestplate" or 
						defName="VAE_Apparel_Chainmail" or 
						defName="VAE_Apparel_PlateHelmet"]/colorGenerator</xpath>
					<value>
						<colorGenerator Class="ColorGenerator_Options">
							<options>
								<li>
								<weight>10</weight>
								<only>(0.33,0.33,0.33)</only>
								</li>
								<li>
								<weight>10</weight>
								<only>(0.65,0.65,0.65)</only>
								</li>
								<li>
								<weight>6</weight>
								<min>(0.3,0.3,0.3)</min>
								<max>(0.5,0.5,0.5)</max>
								</li>
							</options>
						</colorGenerator>
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_LightPlateArmor" or 
						defName="VAE_Apparel_PlateShoulderpads" or 
						defName="VAE_Apparel_Chestplate" or 
						defName="VAE_Apparel_Chainmail" or 
						defName="VAE_Apparel_PlateHelmet"]/recipeMaker</xpath>
					<value>
						<unfinishedThingDef>UnfinishedMetallicTechArmor</unfinishedThingDef>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_LightPlateArmor" or 
						defName="VAE_Apparel_PlateShoulderpads" or 
						defName="VAE_Apparel_Chestplate" or 
						defName="VAE_Apparel_Chainmail" or 
						defName="VAE_Apparel_PlateHelmet"]/recipeMaker/skillRequirements</xpath>
					<value>
						<skillRequirements>
        					<Crafting>7</Crafting>
						</skillRequirements>
					</value>
				</li>

				<!-- medieval -->
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_PlateShoulderpads"]/equippedStatOffsets/MoveSpeed</xpath>
					<value>
						<MoveSpeed>-0.1</MoveSpeed>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_PlateHelmet"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
					<value>
						<ShootingAccuracyPawn>-2</ShootingAccuracyPawn>
					</value>
				</li>

				<!-- industrial -->
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VAE_Headgear_GhillieHood"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
					<value>
						<ShootingAccuracyPawn>4</ShootingAccuracyPawn>
					</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="VAE_Headgear_HAZMATMask"]/apparel/bodyPartGroups/li[text()="Eyes"]</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VAE_Headgear_HAZMATMask"]/apparel/bodyPartGroups</xpath>
					<value>
						<li>FullHead</li>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_GhillieSuit"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
					<value>
						<ShootingAccuracyPawn>4</ShootingAccuracyPawn>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VAE_Apparel_RiotArmor"]/equippedStatOffsets/MoveSpeed</xpath>
					<value>
						<MoveSpeed>-0.1</MoveSpeed>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[thingClass="VEF.Apparels.Apparel_Shield"]/equippedStatOffsets/MeleeDodgeChance</xpath>
					<value>
						<MeleeDodgeChance>-4</MeleeDodgeChance>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Factions Expanded - Empire</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[@Name="VFEE_Apparel_AbsolverHelmet"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
					<value>
						<ShootingAccuracyPawn>8</ShootingAccuracyPawn>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[@Name="VFEE_Apparel_DeserterHelmet"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
					<value>
						<ShootingAccuracyPawn>4</ShootingAccuracyPawn>
					</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="VFEE_Apparel_ArmorDeserter"]/equippedStatOffsets/PsychicSensitivity</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VFEE_Apparel_ArmorDeserter"]/equippedStatOffsets</xpath>
					<value>
						<PsychicSensitivityOffset>0.2</PsychicSensitivityOffset>
					</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="VFEE_Apparel_ArmorAbsolver"]/apparel/layers/li[text()="OnSkin"]</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VFEE_Apparel_ArmorAbsolver"]/apparel/layers</xpath>
					<value>
						<li>Shell</li>
					</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/ThingDef[defName="VFEE_Apparel_ArmorAbsolver"]/modExtensions/li[@Class="VEF.Apparels.ApparelExtension"]/equippedStatFactors/MoveSpeed</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="VFEE_Apparel_ArmorAbsolver"]/equippedStatOffsets</xpath>
					<value>
						<MoveSpeed>0.6</MoveSpeed>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Fungoid</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[@Name="VREF_ApparelArmorAstrosuitBase"]/equippedStatOffsets/MoveSpeed</xpath>
			<value>
				<MoveSpeed>-0.4</MoveSpeed>
			</value>
		</match>
	</Operation>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Weapons Expanded - Heavy Weapons</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VWE_Apparel_Exoframe"]/equippedStatOffsets/WorkSpeedGlobal</xpath>
					<value>
						<WorkSpeedGlobal>0.1</WorkSpeedGlobal>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/ThingDef[defName="VWE_Apparel_Exoframe"]/equippedStatOffsets/VEF_MassCarryCapacity</xpath>
					<value>
						<VEF_MassCarryCapacity>20</VEF_MassCarryCapacity>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

</Patch>
