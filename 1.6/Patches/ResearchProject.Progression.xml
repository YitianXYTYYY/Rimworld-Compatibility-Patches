				<li Operation="SafeAdd" Compare="InnerText">Mortars</li>
			</prerequisites>
		</value>
	</Operation>
	<Operation Class="XmlExtensions.SetScope">
		<xpath>Defs/ResearchProjectDef[defName="TubeTelevision"]</xpath>
		<apply>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaexpanded.vfecore</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ResearchProjectDef</xpath>
						<value>
							<prerequisites Operation="Safe">
								<li Operation="SafeRemove" Compare="InnerText">Electricity</li>
								<li Operation="SafeAdd" Compare="InnerText">MF_ModernFurniture</li>
							</prerequisites>
							<hiddenPrerequisites Operation="Safe">
								<li Operation="SafeAdd" Compare="InnerText">ComplexFurniture</li>
								<li Operation="SafeAdd" Compare="InnerText">Electricity</li>
							</hiddenPrerequisites>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
		</apply>
	</Operation>
