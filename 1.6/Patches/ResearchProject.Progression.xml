<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Electricity -->
	<Operation Class="XmlExtensions.HybridPatch">
		<xpath>Defs/ResearchProjectDef[defName="Batteries" or 
			defName="WatermillGenerator" or 
			defName="SolarPanels" or 
			defName="GeothermalPower"]</xpath>
		<value>
			<prerequisites Operation="Safe">
				<li Operation="SafeRemove" Compare="InnerText">Electricity</li>
			</prerequisites>
			<hiddenPrerequisites Operation="Safe">
				<li Operation="SafeAdd" Compare="InnerText">Electricity</li>
				<li Operation="SafeAdd" Compare="InnerText">MicroelectronicsBasics</li>
			</hiddenPrerequisites>
		</value>
	</Operation>
