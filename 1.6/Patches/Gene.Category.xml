				<value>
					<displayPriorityInXenotype Operation="AddOrReplace">250</displayPriorityInXenotype>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneCategoryDef[defName="Drugs"]</xpath>
				<value>
					<displayPriorityInXenotype Operation="AddOrReplace">200</displayPriorityInXenotype>
				</value>
			</Operation>
			<!-- Vanilla Races Expanded - Fungoid -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.fungoid</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
