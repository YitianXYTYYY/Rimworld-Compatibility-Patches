			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneCategoryDef[defName="Beauty"]</xpath>
				<value>
					<displayPriorityInXenotype Operation="AddOrReplace">270</displayPriorityInXenotype>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>RedMattis.BetterPrerequisites</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneCategoryDef[defName="ForcedSex"]</xpath>
						<value>
							<displayPriorityInXenotype Operation="AddOrReplace">260</displayPriorityInXenotype>
