<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>Ludeon.RimWorld.Biotech</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- ReSplice: Core -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>resplice.xotr.core</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneCategoryDef[defName="RS_DarkArchite"]</xpath>
						<value>
							<displayPriorityInXenotype Operation="AddOrReplace">1100</displayPriorityInXenotype>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<!-- Vanilla Quests Expanded - Ancients -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaquestsexpanded.ancients</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneCategoryDef[defName="VQEA_ArchiteAptitudes"]</xpath>
						<value>
							<displayPriorityInXenotype Operation="AddOrReplace">990</displayPriorityInXenotype>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<!-- Vanilla Races Expanded - Lycanthrope -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.lycanthrope</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneCategoryDef[defName="VRE_Morphs"]</xpath>
						<value>
							<displayPriorityInXenotype Operation="AddOrReplace">720</displayPriorityInXenotype>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneCategoryDef[defName="Ability"]</xpath>
				<value>
					<displayPriorityInXenotype Operation="AddOrReplace">700</displayPriorityInXenotype>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneCategoryDef[defName="Hemogen"]</xpath>
				<value>
					<displayPriorityInXenotype Operation="AddOrReplace">690</displayPriorityInXenotype>
				</value>
			</Operation>
			<!-- Vanilla Races Expanded - Waster -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.waster</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneCategoryDef[defName="VREW_Mutations"]</xpath>
						<value>
							<displayPriorityInXenotype Operation="AddOrReplace">680</displayPriorityInXenotype>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneCategoryDef[defName="Psychic"]</xpath>
				<value>
					<displayPriorityInXenotype Operation="AddOrReplace">600</displayPriorityInXenotype>
				</value>
			</Operation>
			<!-- Integrated Genes -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>Turnovus.Biotech.IntegratedGenes</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneCategoryDef[defName="Turn_GeneCategory_Fleshbeast"]</xpath>
						<value>
							<displayPriorityInXenotype Operation="AddOrReplace">519</displayPriorityInXenotype>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneCategoryDef[defName="Turn_GeneCategory_Slavery"]</xpath>
						<value>
							<displayPriorityInXenotype Operation="AddOrReplace">320</displayPriorityInXenotype>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneCategoryDef[defName="Turn_GeneCategory_Ideology"]</xpath>
						<value>
							<displayPriorityInXenotype Operation="AddOrReplace">290</displayPriorityInXenotype>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneCategoryDef[defName="ResistanceAndWeakness"]</xpath>
				<value>
					<displayPriorityInXenotype Operation="AddOrReplace">490</displayPriorityInXenotype>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneCategoryDef[defName="Violence"]</xpath>
				<value>
					<displayPriorityInXenotype Operation="AddOrReplace">400</displayPriorityInXenotype>
