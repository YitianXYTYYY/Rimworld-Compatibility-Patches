			</Operation>
			<!-- Vanilla Races Expanded - Genie -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.genie</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneCategoryDef[defName="VRE_Curiosity"]</xpath>
						<value>
							<displayPriorityInXenotype Operation="AddOrReplace">90</displayPriorityInXenotype>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneCategoryDef[defName="Miscellaneous"]</xpath>
				<value>
					<displayPriorityInXenotype Operation="AddOrReplace">0</displayPriorityInXenotype>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

	<Operation Class="XmlExtensions.HybridPatch">
		<xpath>Defs/GeneCategoryDef[defName="Cosmetic"]</xpath>
		<value>
			<displayPriorityInGenepack Operation="SafeRemove"/>
			<displayPriorityInXenotype Operation="AddOrReplace">-200</displayPriorityInXenotype>
		</value>
	</Operation>
	<Operation Class="XmlExtensions.HybridPatch">
		<xpath>Defs/GeneCategoryDef[defName="Cosmetic_Skin"]</xpath>
		<value>
			<displayPriorityInGenepack Operation="SafeRemove"/>
			<displayPriorityInXenotype Operation="AddOrReplace">-1020</displayPriorityInXenotype>
		</value>
	</Operation>

</Patch>
