<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Biotech for Gravship -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>als.biotechgravship</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- Progression: Genetics -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>ferny.progressiongenetics</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/ThingDef[defName="BfG_GeneBank"]</xpath>
						<value>
							<researchPrerequisites Operation="Safe">
								<li Operation="SafeAdd" Compare="InnerText">GR_GeneticAlteration</li>
							</researchPrerequisites>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/ThingDef[defName="BfG_GeneExtractor"]</xpath>
						<value>
							<researchPrerequisites Operation="Safe">
								<li Operation="SafeRemove" Compare="InnerText">Xenogermination</li>
								<li Operation="SafeAdd" Compare="InnerText">GR_GeneticAlteration</li>
							</researchPrerequisites>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<!-- Progression: Robotics -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>ferny.progressionrobotics2</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/ThingDef[defName="BfG_BandNode"]</xpath>
						<value>
							<researchPrerequisites Operation="Safe">
								<li Operation="SafeRemove" Compare="InnerText">BasicMechtech</li>
								<li Operation="SafeAdd" Compare="InnerText">Ferny_BandNode</li>
							</researchPrerequisites>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/ThingDef[defName="BfG_MechBooster"]</xpath>
						<value>
							<researchPrerequisites Operation="Safe">
								<li Operation="SafeRemove" Compare="InnerText">HighMechtech</li>
								<li Operation="SafeAdd" Compare="InnerText">Ferny_MechBooster</li>
							</researchPrerequisites>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- Genepack Reprocessor -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>anonemous2.genepackreprocessor</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- genepack reprocessor -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="GeneSeparator"]</xpath>
				<apply>
					<!-- Progression: Genetics -->
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>ferny.progressiongenetics</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>ThingDef</xpath>
								<value>
									<researchPrerequisites Operation="Safe">
										<li Operation="SafeRemove" Compare="InnerText">GeneProcessor</li>
										<li Operation="SafeAdd" Compare="InnerText">Ferny_GenepackCentrifuge</li>
									</researchPrerequisites>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- Vanilla Helixien Gas Expanded -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaexpanded.helixiengas</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- gravship hull -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="RB_SmoothGravshipHull"]</xpath>
				<value>
					<label Operation="SafeReplace">smooth gravship hull</label>
					<terrainAffordanceNeeded Operation="SafeReplace">Substructure</terrainAffordanceNeeded>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="RB_GravshipWindowHull" or 
					defName="RB_GravshipPanoramaHull"]</xpath>
				<value>
					<terrainAffordanceNeeded Operation="SafeReplace">Substructure</terrainAffordanceNeeded>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- Reel's Expanded Storage -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>reel.expanded.storage</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- medical cabinet -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="ReelStorageNewMedicineCabinet"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>vanillaracesexpanded.sanguophage</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>ThingDef</xpath>
								<value>
									<building Operation="Safe">
										<fixedStorageSettings Operation="Safe">
											<filter Operation="Safe">
												<thingDefs Operation="Safe">
													<li Operation="SafeAdd" Compare="InnerText">VRE_HemogenPack_Animal</li>
													<li Operation="SafeAdd" Compare="InnerText">VRE_HemogenPack_Corpse</li>
													<li Operation="SafeAdd" Compare="InnerText">VRE_HemogenPack_Sanguophage</li>
												</thingDefs>
											</filter>
										</fixedStorageSettings>
									</building>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- Vanilla Helixien Gas Expanded -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaexpanded.helixiengas</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- gas cooler -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="VHGE_GasCooler"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef</xpath>
						<value>
							<blockLight Operation="SafeRemove"/>
							<building Operation="Safe">
								<canPlaceOverWall Operation="SafeRemove">true</canPlaceOverWall>
							</building>
							<canOverlapZones Operation="SafeRemove"/>
							<castEdgeShadows Operation="SafeRemove"/>
							<coversFloor Operation="SafeRemove"/>
							<minifiedDef Operation="SafeAdd">MinifiedThing</minifiedDef>
							<pathCost Operation="SafeAdd">40</pathCost>
							<staticSunShadowHeight Operation="SafeRemove"/>
							<terrainAffordanceNeeded Operation="SafeReplace">Light</terrainAffordanceNeeded>
							<thingCategories Operation="Safe">
								<li Operation="SafeAdd" Compare="InnerText">BuildingsTemperature</li>
							</thingCategories>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
