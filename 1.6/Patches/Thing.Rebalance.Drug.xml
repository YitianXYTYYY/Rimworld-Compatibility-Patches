<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>ludeon.rimworld.anomaly</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- juggernaut serum -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="JuggernautSerum"]/stages/li</xpath>
				<value>
					<capMods Operation="Safe">
						<li Operation="Safe" Compare="InnerText" XPathLocal="capacity">
							<capacity Operation="SafeAdd">Moving</capacity>
							<offset Operation="SafeAdd">0.1</offset>
						</li>
					</capMods>
					<statFactors Operation="Safe">
						<MeleeDamageFactor Operation="SafeRemove">0</MeleeDamageFactor>
						<InjuryHealingFactor Operation="SafeRemove">0</InjuryHealingFactor>
					</statFactors>
					<statOffsets Operation="Safe">
						<InjuryHealingFactor Operation="SafeAdd">1</InjuryHealingFactor>
						<MeleeDamageFactor Operation="SafeAdd">0.5</MeleeDamageFactor>
						<MoveSpeed Operation="SafeRemove">0</MoveSpeed>
					</statOffsets>
				</value>
			</Operation>
			<!-- metalblood serum -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="Metalblood"]/stages/li</xpath>
				<value>
					<statFactors Operation="Safe">
						<IncomingDamageFactor Operation="SafeReplace">0.5</IncomingDamageFactor>
					</statFactors>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- Vanilla Factions Expanded - Empire -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>oskarpotocki.vfe.empire</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- Aperitif -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="VFEE_Aperitif"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef</xpath>
						<value>
							<ingestible Operation="Safe">
								<drugCategory Operation="SafeReplace">Social</drugCategory>
							</ingestible>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- Vanilla Factions Expanded - Insectoids 2 -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>oskarpotocki.vfe.insectoid2</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- Royal Insect Jelly -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="VFEI2_RoyalInsectJelly"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef</xpath>
						<value>
							<ingestible Operation="Safe">
								<drugCategory Operation="SafeReplace">Social</drugCategory>
							</ingestible>
							<thingCategories Operation="Safe">
								<li Operation="SafeRemove" Compare="InnerText">AnimalProductRaw</li>
							</thingCategories>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- Vanilla Genetics Expanded -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaexpanded.vgeneticse</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- Mechanoid Egg -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="GR_ElectroEgg"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef</xpath>
						<value>
							<ingestible Operation="Safe">
								<drugCategory Operation="SafeReplace">Medical</drugCategory>
							</ingestible>
							<tradeability Operation="SafeRemove"/>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef/ingestible/outcomeDoers/li[@Class="IngestionOutcomeDoer_GiveHediff" and hediffDef="GR_ElectroEggTolerance"]</xpath>
						<value>
							<multiplyByGeneToleranceFactors Operation="SafeAdd">true</multiplyByGeneToleranceFactors>
							<toleranceChemical Operation="SafeAdd">GR_ElectroEgg</toleranceChemical>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ChemicalDef[defName="GR_ElectroEgg"]</xpath>
				<value>
					<geneToleranceBuildupFactorResist Operation="SafeAdd">0.5</geneToleranceBuildupFactorResist>
					<geneToleranceBuildupFactorImmune Operation="SafeAdd">0</geneToleranceBuildupFactorImmune>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="GR_ElectroEggHigh"]</xpath>
				<value>
					<comps Operation="Safe">
						<li Class="HediffCompProperties_SeverityPerDay" Operation="Safe" CheckAttributes="True">
							<severityPerDay Operation="SafeReplace">-0.75</severityPerDay>
							<showHoursToRecover Operation="SafeAdd">true</showHoursToRecover>
						</li>
					</comps>
				</value>
			</Operation>
			<!-- Featherdust Joint -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="GR_FeatherdustJoint"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef</xpath>
						<value>
							<tradeability Operation="SafeRemove"/>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef/ingestible/outcomeDoers/li[@Class="IngestionOutcomeDoer_GiveHediff" and hediffDef="GR_FeatherdustTolerance"]</xpath>
						<value>
							<multiplyByGeneToleranceFactors Operation="SafeAdd">true</multiplyByGeneToleranceFactors>
							<toleranceChemical Operation="SafeAdd">GR_Featherdust</toleranceChemical>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ChemicalDef[defName="GR_Featherdust"]</xpath>
				<value>
					<geneToleranceBuildupFactorResist Operation="SafeAdd">0.5</geneToleranceBuildupFactorResist>
					<geneToleranceBuildupFactorImmune Operation="SafeAdd">0</geneToleranceBuildupFactorImmune>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/HediffDef[defName="GR_FeatherdustTolerance"]</xpath>
				<value>
					<comps Operation="Safe">
						<li Class="HediffCompProperties_SeverityPerDay" Operation="Safe" CheckAttributes="True">
							<showHoursToRecover Operation="SafeAdd">true</showHoursToRecover>
						</li>
					</comps>
					<stages Operation="Safe">
						<li Operation="Safe">
							<hungerRateFactor Operation="SafeRemove">0</hungerRateFactor>
							<hungerRateFactorOffset Operation="SafeAdd">0.1</hungerRateFactorOffset>
						</li>
					</stages>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
