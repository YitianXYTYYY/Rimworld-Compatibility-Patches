		</mods>
		<match Class="PatchOperationAdd">
			<xpath>Defs/GeneCategoryDef[defName="VRE_Curiosity"]</xpath>
			<value>
				<displayPriorityInGenepack>199</displayPriorityInGenepack>
			</value>
		</match>
