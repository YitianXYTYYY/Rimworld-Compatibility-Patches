<?xml version="1.0" encoding="utf-8"?>
<Patch>	<!-- Genepack Priority -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneCategoryDef[defName="Mood"]/displayPriorityInXenotype</xpath>
		<value>
			<displayPriorityInXenotype>390</displayPriorityInXenotype>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneCategoryDef[defName="Violence"]/displayPriorityInXenotype</xpath>
		<value>
			<displayPriorityInXenotype>380</displayPriorityInXenotype>
		</value>
	</Operation>

	<!-- Modded Categories -->
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Quests Expanded - Ancients</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/GeneCategoryDef[defName="VQEA_ArchiteAptitudes"]/displayPriorityInXenotype</xpath>
			<value>
				<displayPriorityInXenotype>999</displayPriorityInXenotype>
			</value>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Hussar</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/GeneCategoryDef[defName="VREH_WeaponAptitudes"]/displayPriorityInXenotype</xpath>
			<value>
				<displayPriorityInXenotype>998</displayPriorityInXenotype>
			</value>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Lycanthrope</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/GeneCategoryDef[defName="VRE_Morphs"]/displayPriorityInXenotype</xpath>
			<value>
				<displayPriorityInXenotype>900</displayPriorityInXenotype>
			</value>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>ReSplice: Core</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/GeneCategoryDef[defName="RS_DarkArchite"]/displayPriorityInXenotype</xpath>
			<value>
				<displayPriorityInXenotype>521</displayPriorityInXenotype>
			</value>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Integrated Genes</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneCategoryDef[defName="Turn_GeneCategory_Fleshbeast"]/displayPriorityInXenotype</xpath>
					<value>
						<displayPriorityInXenotype>499</displayPriorityInXenotype>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneCategoryDef[defName="Turn_GeneCategory_Slavery"]/displayPriorityInXenotype</xpath>
					<value>
						<displayPriorityInXenotype>379</displayPriorityInXenotype>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

</Patch>
