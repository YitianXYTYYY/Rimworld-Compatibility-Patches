<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaquestsexpanded.ancients</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VQEA_Herculean"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/statFactors</xpath>
						<value>
							<MeleeDamageFactor Operation="SafeRemove"/>
							<VEF_MassCarryCapacity Operation="SafeRemove"/>
							<CarryingCapacity Operation="SafeRemove"/>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<MeleeDamageFactor Operation="AddOrReplace">2</MeleeDamageFactor>
								<CarryingCapacity Operation="AddOrReplace">150</CarryingCapacity>
								<VEF_MassCarryCapacity Operation="AddOrReplace">70</VEF_MassCarryCapacity>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VQEA_Prowess"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/VQEA_Prowess</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<VQEA_Prowess Operation="AddOrReplace">1</VQEA_Prowess>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VQEA_BlurRunner"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/MoveSpeed</xpath>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeAdd">
						<xpath>GeneDef</xpath>
						<value>
							<capMods>
								<li>
									<capacity>Moving</capacity>
									<offset>0.2</offset>
								</li>
							</capMods>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VQEA_Woundless"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/InjuryHealingFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="AddOrReplace">7</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VQEA_Marksman"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<ShootingAccuracyPawn Operation="SafeReplace">12</ShootingAccuracyPawn>
					</statOffsets>
					<statFactors Operation="Safe">
						<AimingDelayFactor Operation="AddOrReplace">0.5</AimingDelayFactor>
						<RangedCooldownFactor Operation="SafeReplace">0.8</RangedCooldownFactor>
					</statFactors>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VQEA_PerfectVision"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/statFactors</xpath>
						<value>
							<ShootingAccuracyFactor_Long Operation="SafeRemove"/>
							<ShootingAccuracyFactor_Medium Operation="SafeRemove"/>
							<VEF_VerbRangeFactor Operation="SafeRemove"/>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<WorkSpeedGlobal Operation="AddOrReplace">0.1</WorkSpeedGlobal>
								<ShootingAccuracyPawn Operation="AddOrReplace">4</ShootingAccuracyPawn>
								<MeleeHitChance Operation="AddOrReplace">4</MeleeHitChance>
								<MeleeDodgeChance Operation="AddOrReplace">8</MeleeDodgeChance>
								<VEF_VerbRangeFactor Operation="AddOrReplace">0.2</VEF_VerbRangeFactor>
							</statOffsets>
							<exclusionTags Operation="Safe">
								<li Operation="SafeAdd" Compare="InnerText">VRE_SuperiorDarkVision</li>
							</exclusionTags>	
						</value>
					</Operation>
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>Turnovus.Biotech.IntegratedGenes</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="XmlExtensions.PatchOperationSafeRemove">
								<xpath>GeneDef/exclusionTags/li[text()="ShootingAccuracy"]</xpath>
							</Operation>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>GeneDef</xpath>
								<value>
									<exclusionTags Operation="Safe">
										<li Operation="SafeAdd" Compare="InnerText">Turn_Exclusion_NightVision</li>
										<li Operation="SafeAdd" Compare="InnerText">Turn_Exclusion_NearSighted</li>
										<li Operation="SafeAdd" Compare="InnerText">Turn_Exclusion_Blindness</li>
									</exclusionTags>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.lycanthrope</li>
				</mods>
				<packageId>true</packageId>
				<caseFalse>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>/Defs/GeneDef[defName = "DarkVision"]</xpath>
						<value>
							<exclusionTags Operation="Safe">
								<li Operation="SafeAdd" Compare="InnerText">VRE_SuperiorDarkVision</li>
							</exclusionTags>
						</value>
					</Operation>
				</caseFalse>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VQEA_PlasteelSkin"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/modExtensions/li[@Class="VEF.Genes.GeneExtension"]</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<customEffectDescriptions Operation="SafeRemove"/>
							<statOffsets Operation="Safe">
								<ArmorRating_Sharp Operation="AddOrReplace">0.60</ArmorRating_Sharp>
								<ArmorRating_Blunt Operation="AddOrReplace">0.40</ArmorRating_Blunt>
								<ArmorRating_Heat Operation="AddOrReplace">1.60</ArmorRating_Heat>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VQEA_Genius"]</xpath>
				<value>
					<statOffsets Operation="Safe">
						<VEF_GrowthPointMultiplier Operation="AddOrReplace">2</VEF_GrowthPointMultiplier>
					</statOffsets>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="VQEA_Enormous"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/statFactors</xpath>
						<value>
							<MeatAmount Operation="SafeRemove"/>
							<LeatherAmount Operation="SafeRemove"/>
							<MeleeDodgeChance Operation="SafeReplace">0.2</MeleeDodgeChance>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<statOffsets Operation="Safe">
								<MoveSpeed Operation="SafeReplace">-1</MoveSpeed>
								<VEF_BodySize_Multiplier Operation="AddOrReplace">1</VEF_BodySize_Multiplier>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
