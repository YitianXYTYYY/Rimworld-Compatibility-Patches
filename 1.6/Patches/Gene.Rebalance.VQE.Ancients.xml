					<displayOrderInCategory Operation="AddOrReplace">11</displayOrderInCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VQEA_MasterfulIntellectual"]</xpath>
				<value>
					<displayOrderInCategory Operation="AddOrReplace">12</displayOrderInCategory>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
