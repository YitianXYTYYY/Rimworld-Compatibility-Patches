			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VQEA_MasterfulAnimals"]</xpath>
				<value>
					<displayOrderInCategory Operation="AddOrReplace">7</displayOrderInCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VQEA_MasterfulCrafting"]</xpath>
