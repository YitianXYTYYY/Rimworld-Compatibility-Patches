<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>Turnovus.Biotech.IntegratedGenes</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- 600 psychic -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="Turn_Gene_SlowNeuralHeat"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<PsychicEntropyRecoveryRate Operation="SafeReplace">0.8</PsychicEntropyRecoveryRate>
					</statFactors>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="Turn_Gene_FastNeuralHeat"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/PsychicEntropyRecoveryRate</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<biostatCpx Operation="AddOrReplace">2</biostatCpx>
							<biostatMet Operation="SafeReplace">-2</biostatMet>
							<statOffsets Operation="Safe">
								<PsychicEntropyRecoveryRate Operation="SafeAdd">0.12</PsychicEntropyRecoveryRate>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="Turn_Gene_VeryFastNeuralHeat"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/PsychicEntropyRecoveryRate</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<biostatCpx Operation="AddOrReplace">3</biostatCpx>
							<biostatMet Operation="SafeReplace">-5</biostatMet>
							<statOffsets Operation="Safe">
								<PsychicEntropyRecoveryRate Operation="SafeAdd">0.3</PsychicEntropyRecoveryRate>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<!-- 500 health -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="Turn_Gene_BiosculptAccelerated"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Healing</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">1000</displayOrderInCategory>
					<statOffsets Operation="Safe">
						<BiosculpterOccupantSpeed Operation="SafeReplace">0.4</BiosculpterOccupantSpeed>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="Turn_Gene_BiosculptNeed"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Healing</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">1010</displayOrderInCategory>
					<statOffsets Operation="Safe">
						<BiosculpterOccupantSpeed Operation="SafeReplace">0.2</BiosculpterOccupantSpeed>
					</statOffsets>
				</value>
			</Operation>

			<!-- 380 melee -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="Turn_Gene_Duelist"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Violence_Melee</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">300</displayOrderInCategory>
							<statOffsets Operation="Safe">
								<MeleeHitChance Operation="SafeAdd">4</MeleeHitChance>
								<MeleeDodgeChance Operation="SafeAdd">8</MeleeDodgeChance>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/statFactors</xpath>
						<value>
							<MeleeHitChance Operation="SafeRemove"/>
							<MeleeDodgeChance Operation="SafeRemove"/>
						</value>
					</Operation>
				</apply>
			</Operation>

			<!-- 290 melee -->		
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="Turn_Gene_FreeSpirit"]</xpath>
				<value>
					<statFactors Operation="Safe">
						<RoyalFavorValue MayRequire="Ludeon.RimWorld.Royalty" Operation="SafeReplace">0.2</RoyalFavorValue>
					</statFactors>
					<prisonBreakMTBFactor Operation="SafeReplace">0.8</prisonBreakMTBFactor>
				</value>
			</Operation>

			<!-- 0 miscellaneous -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="Turn_Gene_MotivationLow"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<displayOrderInCategory Operation="AddOrReplace">-1000</displayOrderInCategory>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef/statFactors</xpath>
						<value>
							<GeneralLaborSpeed Operation="SafeRemove"/>
							<WorkSpeedGlobal Operation="SafeReplace">0.8</WorkSpeedGlobal>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/GeneDef[defName="Turn_Gene_MotivationHigh"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>GeneDef</xpath>
						<value>
							<displayOrderInCategory Operation="AddOrReplace">-990</displayOrderInCategory>
							<statOffsets Operation="Safe">
								<WorkSpeedGlobal Operation="SafeAdd">0.2</WorkSpeedGlobal>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>GeneDef/statFactors/GeneralLaborSpeed</xpath>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
