<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.highmate</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- 400 violence -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_Harmless"]</xpath>
				<value>
					<displayOrderInCategory Operation="AddOrReplace">-90</displayOrderInCategory>
				</value>
			</Operation>

			<!-- -200 bodytype -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_PerfectBody"]</xpath>
				<value>
					<iconColor Operation="SafeAdd">(0.75, 0.75, 0.75)</iconColor>
					<displayCategory Operation="AddOrReplace">Cosmetic_BodyType</displayCategory>
					<displayOrderInCategory Operation="AddOrReplace">5000</displayOrderInCategory>
				</value>
			</Operation>

			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>RedMattis.BetterGeneInheritance</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="BGI_RecessiveGenes"]</xpath>
						<value>
							<biostatMet Operation="SafeReplace">1</biostatMet>
							<displayOrderInCategory Operation="AddOrReplace">2000</displayOrderInCategory>
							<iconPath Operation="SafeReplace">UI/Icons/Genes/Gene_GenomeRecessive</iconPath>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="BGI_DominantGenes"]</xpath>
						<value>
							<biostatMet Operation="SafeReplace">-2</biostatMet>
							<displayOrderInCategory Operation="AddOrReplace">2001</displayOrderInCategory>
							<iconPath Operation="SafeReplace">UI/Icons/Genes/Gene_GenomeDominant</iconPath>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
