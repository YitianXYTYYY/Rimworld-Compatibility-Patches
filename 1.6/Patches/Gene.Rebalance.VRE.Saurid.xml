<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.saurid</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRESaurids_ScaleSkin"]</xpath>
				<value>
					<biostatMet Operation="SafeReplace">-2</biostatMet>
					<statOffsets Operation="Safe">
						<ArmorRating_Sharp Operation="SafeReplace">0.4</ArmorRating_Sharp>
					</statOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRESaurids_SauridClaws"]/capMods/li[capacity="Manipulation"]</xpath>
				<value>
					<postFactor Operation="SafeRemove"/>
					<offset Operation="SafeAdd">-0.05</offset>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
