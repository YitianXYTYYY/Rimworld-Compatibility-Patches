<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>reel.turretpipeline</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/RecipeDef[defName="Make_TurretAmmo"]</xpath>
				<value>
					<workAmount Operation="SafeReplace">360</workAmount>
					<ingredients Operation="SafeReplace">
						<li>
							<filter>
								<thingDefs>
									<li>Uranium</li>
								</thingDefs>
							</filter>
							<count>4</count>
						</li>
						<li>
							<filter>
								<thingDefs>
									<li>Steel</li>
								</thingDefs>
							</filter>
							<count>20</count>
						</li>
					</ingredients>
					<products Operation="Safe">
						<ReelTurretAmmo Operation="SafeReplace">25</ReelTurretAmmo>
					</products>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/RecipeDef[defName="Make_TurretAmmoBulk"]</xpath>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="ReelTurretAmmo"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef</xpath>
						<value>
							<stackLimit Operation="SafeReplace">150</stackLimit>
							<statBases Operation="Safe">
								<MarketValue Operation="SafeReplace">2.5</MarketValue>
							</statBases>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.FindMod">
						<mods>
							<li>mlie.yayoscombat3</li>
						</mods>
						<packageId>true</packageId>
						<caseTrue>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>ThingDef/thingCategories</xpath>
								<value>
									<li Operation="SafeAdd" Compare="InnerText">yy_ammo_category</li>
									<li Operation="SafeRemove" Compare="InnerText">Manufactured</li>
								</value>
							</Operation>
						</caseTrue>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

