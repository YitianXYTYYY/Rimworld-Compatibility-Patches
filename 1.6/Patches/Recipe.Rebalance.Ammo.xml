				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/RecipeDef[defName="Make_TurretAmmo"]/ingredients</xpath>
					<value>
						<ingredients>
							<li>
								<filter>
									<thingDefs>
										<li>Uranium</li>
									</thingDefs>
								</filter>
								<count>2</count>
							</li>
							<li>
								<filter>
