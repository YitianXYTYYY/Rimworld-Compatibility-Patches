<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.fungoid</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_FungalArmor"]/stages</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeReplace">
						<xpath>stages/li[minSeverity="0.1"]/statFactors/IncomingDamageFactor</xpath>
						<value>
							<IncomingDamageFactor>0.5</IncomingDamageFactor>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeReplace">
						<xpath>stages/li[minSeverity="0.4"]/statFactors/IncomingDamageFactor</xpath>
						<value>
							<IncomingDamageFactor>0.8</IncomingDamageFactor>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeReplace">
						<xpath>stages/li[minSeverity="0.9"]/statFactors/IncomingDamageFactor</xpath>
						<value>
							<IncomingDamageFactor>0.9</IncomingDamageFactor>
						</value>
					</Operation>
				</apply>
			</Operation>

			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_FungalRegeneration"]/stages</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>stages/li/statFactors/InjuryHealingFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
						<xpath>stages/li[minSeverity="0.1"]</xpath>
						<value>
							<statOffsets>
								<InjuryHealingFactor>5</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
						<xpath>stages/li[minSeverity="0.4"]</xpath>
						<value>
							<statOffsets>
								<InjuryHealingFactor>3</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeAddOrReplace">
						<xpath>stages/li[minSeverity="0.9"]</xpath>
						<value>
							<statOffsets>
								<InjuryHealingFactor>1</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
