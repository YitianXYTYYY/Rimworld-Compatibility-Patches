<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Biotech -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>ludeon.rimworld.biotech</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="PsychicBond"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeReplace">
						<xpath>HediffDef/stages/li[minSeverity="0"]/statOffsets</xpath>
						<value>
							<PsychicSensitivity>0.2</PsychicSensitivity>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeReplace">
						<xpath>HediffDef/stages/li[minSeverity="0"]/capMods/li[capacity="Consciousness"]</xpath>
						<value>
							<offset>0.1</offset>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li[minSeverity="1"]/statOffsets/PsychicSensitivity</xpath>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeReplace">
						<xpath>HediffDef/stages/li[minSeverity="1"]/capMods/li[capacity="Consciousness"]</xpath>
						<value>
							<offset>-0.2</offset>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- VRE.Fungoid -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.fungoid</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_FungalArmor"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[minSeverity="0.1"]</xpath>
						<value>
							<statFactors Operation="Safe">
								<IncomingDamageFactor Operation="SafeReplace">0.5</IncomingDamageFactor>
							</statFactors>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[minSeverity="0.4"]</xpath>
						<value>
							<statFactors Operation="Safe">
								<IncomingDamageFactor Operation="SafeReplace">0.8</IncomingDamageFactor>
							</statFactors>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[minSeverity="0.9"]</xpath>
						<value>
							<statFactors Operation="Safe">
								<IncomingDamageFactor Operation="SafeReplace">0.9</IncomingDamageFactor>
							</statFactors>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_FungalRegeneration"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/InjuryHealingFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[minSeverity="0.1"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="SafeAdd">5</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[minSeverity="0.4"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="SafeAdd">3</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[minSeverity="0.9"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="SafeAdd">1</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

	<!-- VRE.Waster -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.waster</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="PollutionStimulus"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef</xpath>
						<value>
							<minSeverity Operation="SafeReplace">0.001</minSeverity>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/comps</xpath>
						<value>
							<li Class="HediffCompProperties_Pollution" Operation="SafeRemove"/>
							<li Class="VanillaRacesExpandedWaster.HediffCompProperties_GeneDependentPollution" Operation="SafeAdd">
								<pollutedSeverity>0.0333</pollutedSeverity>
								<unpollutedSeverity>-0.003</unpollutedSeverity>
								<interval>60</interval>
							</li>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationAdd">
						<xpath>HediffDef/stages</xpath>
						<Order>Prepend</Order>
						<value>
							<li>
								<label>inactive</label>
								<minSeverity>0.01</minSeverity>
							</li>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/MoveSpeed</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="minor"]</xpath>
						<value>
							<minSeverity Operation="SafeAdd">0.02</minSeverity>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="moderate"]</xpath>
						<value>
							<capMods Operation="Safe">
								<li Operation="Add">
									<capacity>Moving</capacity>
									<offset>0.05</offset>
								</li>
							</capMods>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="maximum"]</xpath>
						<value>
							<label Operation="SafeReplace">extreme</label>
							<capMods Operation="Safe">
								<li Operation="Add">
									<capacity>Moving</capacity>
									<offset>0.1</offset>
								</li>
							</capMods>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_PollutionRegeneration"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/InjuryHealingFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>stages/li[label="minor"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="SafeAdd">0.5</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="moderate"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="SafeAdd">1</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="extreme"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<InjuryHealingFactor Operation="SafeAdd">3</InjuryHealingFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_PollutionRage"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/MeleeDamageFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="minor"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<MeleeDamageFactor Operation="SafeAdd">0.1</MeleeDamageFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="moderate"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<MeleeDamageFactor Operation="SafeAdd">0.2</MeleeDamageFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="extreme"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<MeleeDamageFactor Operation="SafeAdd">0.5</MeleeDamageFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_PollutionSustenance"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="minor"]</xpath>
						<value>
							<hungerRateFactor Operation="SafeAdd">0.9</hungerRateFactor>
							<hungerRateFactorOffset Operation="SafeRemove"/>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="moderate"]</xpath>
						<value>
							<hungerRateFactor Operation="SafeAdd">0.8</hungerRateFactor>
							<hungerRateFactorOffset Operation="SafeRemove"/>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="extreme"]</xpath>
						<value>
							<hungerRateFactor Operation="SafeAdd">0.5</hungerRateFactor>
							<hungerRateFactorOffset Operation="SafeRemove"/>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_PollutionCognition"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/GlobalLearningFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="minor"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<GlobalLearningFactor Operation="SafeAdd">0.1</GlobalLearningFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="moderate"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<GlobalLearningFactor Operation="SafeAdd">0.2</GlobalLearningFactor>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="extreme"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<GlobalLearningFactor Operation="SafeAdd">0.5</GlobalLearningFactor>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_PollutionNumbness"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="minor"]</xpath>
						<value>
							<painFactor Operation="SafeReplace">0.9</painFactor>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="moderate"]</xpath>
						<value>
							<painFactor Operation="SafeReplace">0.8</painFactor>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="extreme"]</xpath>
						<value>
							<painFactor Operation="SafeReplace">0.5</painFactor>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_PollutionProductivity"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/WorkSpeedGlobal</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="minor"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<WorkSpeedGlobal Operation="SafeAdd">0.05</WorkSpeedGlobal>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="moderate"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<WorkSpeedGlobal Operation="SafeAdd">0.1</WorkSpeedGlobal>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="extreme"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<WorkSpeedGlobal Operation="SafeAdd">0.2</WorkSpeedGlobal>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_PollutionPsySensitivity"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/PsychicSensitivity</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="minor"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<PsychicSensitivity Operation="SafeAdd">0.1</PsychicSensitivity>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="moderate"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<PsychicSensitivity Operation="SafeAdd">0.2</PsychicSensitivity>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="extreme"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<PsychicSensitivity Operation="SafeAdd">0.4</PsychicSensitivity>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/HediffDef[defName="VRE_PollutionAccuracy"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/AccuracyLong</xpath>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>HediffDef/stages/li/statFactors/AccuracyMedium</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="minor"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<ShootingAccuracyPawn Operation="SafeAdd">2</ShootingAccuracyPawn>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="moderate"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<ShootingAccuracyPawn Operation="SafeAdd">4</ShootingAccuracyPawn>
							</statOffsets>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>HediffDef/stages/li[label="extreme"]</xpath>
						<value>
							<statOffsets Operation="Safe">
								<ShootingAccuracyPawn Operation="SafeAdd">8</ShootingAccuracyPawn>
							</statOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
