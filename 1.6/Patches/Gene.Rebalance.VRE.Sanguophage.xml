<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>vanillaracesexpanded.sanguophage</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.PatchOperationSafeReplace">
				<xpath>Defs/GeneDef[defName="VRE_ExtremeHemogenDrain"]/biostatMet</xpath>
				<value>
					<biostatMet>9</biostatMet>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="VRE_Talons"]/capMods/li[capacity="Manipulation"]</xpath>
				<value>
					<postFactor Operation="SafeRemove"/>
					<offset Operation="AddOrReplace">-0.1</offset>
				</value>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
