<?xml version="1.0" encoding="utf-8"?>
<Patch>	

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Sanguophage</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[defName="VRE_ExtremeHemogenDrain"]/biostatMet</xpath>
					<value>
						<biostatMet>9</biostatMet>
					</value>
				</li>
				<li Class="PatchOperationRemove">
					<xpath>Defs/GeneDef[defName="VRE_Talons"]/capMods/li[capacity="Manipulation"]/postFactor</xpath>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/GeneDef[defName="VRE_Talons"]/capMods/li[capacity="Manipulation"]</xpath>
					<value>
						<offset>-0.1</offset>
					</value>
				</li>
			</operations>
		</match>
	</Operation>

</Patch>
