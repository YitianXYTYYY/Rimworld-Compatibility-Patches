<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.HybridPatch">
		<xpath>Defs/ThingDef[defName="Apparel_FlakVest" or defName="Apparel_FlakPants" or defName="Apparel_FlakJacket"]</xpath>
		<value>
			<equippedStatOffsets Operation="Safe">
				<MoveSpeed Operation="SafeReplace">-0.1</MoveSpeed>
			</equippedStatOffsets>
		</value>
	</Operation>
	<Operation Class="XmlExtensions.HybridPatch">
		<xpath>Defs/ThingDef[@Name="ApparelArmorPowerBase"]</xpath>
		<value>
			<equippedStatOffsets Operation="Safe">
				<MoveSpeed Operation="SafeReplace">-0.2</MoveSpeed>
			</equippedStatOffsets>
		</value>
	</Operation>

	<Operation Class="XmlExtensions.SetScope">
		<xpath>Defs/ThingDef[defName="Apparel_PsychicFoilHelmet"]</xpath>
		<apply>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>ThingDef/equippedStatOffsets/PsychicSensitivity</xpath>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>ThingDef</xpath>
				<value>
					<equippedStatOffsets Operation="Safe">
						<PsychicSensitivityOffset Operation="SafeAdd">-0.9</PsychicSensitivityOffset>
					</equippedStatOffsets>
				</value>
			</Operation>
		</apply>
	</Operation>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>Ludeon.RimWorld.Royalty</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- eltex -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="Apparel_PsyfocusHelmet" or defName="Apparel_PsyfocusShirt" or defName="Apparel_PsyfocusVest"]</xpath>
				<value>
					<equippedStatOffsets Operation="Safe">
						<PsychicSensitivityOffset Operation="SafeReplace">0.2</PsychicSensitivityOffset>
					</equippedStatOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="Apparel_PsyfocusRobe"]</xpath>
				<value>
					<equippedStatOffsets Operation="Safe">
						<PsychicSensitivityOffset Operation="SafeReplace">0.4</PsychicSensitivityOffset>
					</equippedStatOffsets>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="MeleeWeapon_PsyfocusStaff"]</xpath>
				<value>
					<equippedStatOffsets Operation="Safe">
						<PsychicSensitivityOffset Operation="SafeReplace">0.6</PsychicSensitivityOffset>
					</equippedStatOffsets>
				</value>
			</Operation>

			<!-- prestige armor -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="Apparel_ArmorReconPrestige" or
					defName="Apparel_ArmorHelmetReconPrestige" or 
					defName="Apparel_ArmorMarinePrestige" or 
					defName="Apparel_ArmorMarineHelmetPrestige" or 
					defName="Apparel_ArmorCataphractPrestige" or 
					defName="Apparel_ArmorHelmetCataphractPrestige"]/equippedStatOffsets</xpath>
				<value>
					<PsychicSensitivity Operation="SafeRemove"/>
					<PsychicSensitivityOffset Operation="SafeAdd">0.1</PsychicSensitivityOffset>
				</value>
			</Operation>

			<!-- gunlink -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="Apparel_Gunlink"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef/apparel/bodyPartGroups</xpath>
						<value>
							<li Operation="SafeRemove" Compare="InnerText">UpperHead</li>
							<li Operation="SafeAdd" Compare="InnerText">Eyes</li>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.PatchOperationAttributeAdd">
						<xpath>ThingDef/equippedStatOffsets</xpath>
						<attribute>Inherit</attribute>
						<value>False</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef/equippedStatOffsets</xpath>
						<value>
							<ShootingAccuracyPawn Operation="SafeReplace">4</ShootingAccuracyPawn>
							<VacuumResistance Operation="SafeRemove"/>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>Ludeon.RimWorld.Biotech</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- headsets -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="Apparel_AirwireHeadset"]/apparel/bodyPartGroups</xpath>
				<value>
					<li Operation="SafeRemove" Compare="InnerText">UpperHead</li>
					<li Operation="SafeAdd" Compare="InnerText">Eyes</li>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="Apparel_ArrayHeadset"]/apparel/bodyPartGroups</xpath>
				<value>
					<li Operation="SafeRemove" Compare="InnerText">UpperHead</li>
					<li Operation="SafeAdd" Compare="InnerText">Eyes</li>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="Apparel_IntegratorHeadset"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef/apparel/bodyPartGroups</xpath>
						<value>
							<li Operation="SafeRemove" Compare="InnerText">UpperHead</li>
							<li Operation="SafeAdd" Compare="InnerText">Eyes</li>
						</value>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef</xpath>
						<value>
							<equippedStatOffsets Inherit="False" Operation="SafeReplace">
								<MechBandwidth>9</MechBandwidth>
							</equippedStatOffsets>
						</value>
					</Operation>
				</apply>
			</Operation>

			<!-- mechlord -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/ThingDef[defName="Apparel_ArmorHelmetMechlordHelmet" or defName="Apparel_MechlordSuit"]</xpath>
				<value>
					<equippedStatOffsets Operation="Safe">
						<ShootingAccuracyPawn Operation="SafeReplace">-4</ShootingAccuracyPawn>
						<MeleeHitChance Operation="SafeReplace">-1</MeleeHitChance>
					</equippedStatOffsets>
				</value>
			</Operation>

			<!-- bandolier -->
			<Operation Class="XmlExtensions.SetScope">
				<xpath>Defs/ThingDef[defName="Apparel_Bandolier"]</xpath>
				<apply>
					<Operation Class="XmlExtensions.PatchOperationSafeRemove">
						<xpath>ThingDef/equippedStatOffsets/RangedCooldownFactor</xpath>
					</Operation>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>ThingDef</xpath>
						<value>
							<modExtensions Operation="Safe">
								<li Class="VEF.Apparels.ApparelExtension" Operation="Add">
									<equippedStatFactors>
										<RangedCooldownFactor>0.8</RangedCooldownFactor>
									</equippedStatFactors>
								</li>
							</modExtensions>
						</value>
					</Operation>
				</apply>
			</Operation>
		</caseTrue>
	</Operation>

