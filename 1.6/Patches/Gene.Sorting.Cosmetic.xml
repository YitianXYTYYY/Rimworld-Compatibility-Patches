						<xpath>Defs/GeneDef[defName="VRE_PerfectBody"]</xpath>
						<apply>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>GeneDef</xpath>
								<value>
									<displayCategory Operation="AddOrReplace">Skin</displayCategory>
									<iconColor Operation="SafeAdd">(0.75, 0.75, 0.75)</iconColor>
								</value>
							</Operation>
							<Operation Class="XmlExtensions.FindMod">
								<mods>
									<li>mac.bettervrehighmates</li>
								</mods>
								<packageId>true</packageId>
								<caseFalse>
									<Operation Class="XmlExtensions.HybridPatch">
										<xpath>GeneDef/exclusionTags</xpath>
										<value>
											<displayOrderInCategory Operation="AddOrReplace">90</displayOrderInCategory>
											<exclusionTags Operation="Safe">
												<li Operation="SafeAdd" Compare="InnerText">Fur</li>
											</exclusionTags>
										</value>
									</Operation>
								</caseFalse>
								<caseTrue>
									<Operation Class="XmlExtensions.HybridPatch">
										<xpath>GeneDef</xpath>
										<value>
											<displayOrderInCategory Operation="AddOrReplace">1000</displayOrderInCategory>
											<exclusionTags Operation="Safe">
												<li Operation="SafeRemove" Compare="InnerText">AG_Bodies</li>
												<li Operation="SafeRemove" Compare="InnerText">Bodies</li>
												<li Operation="SafeRemove" Compare="InnerText">Body</li>
											</exclusionTags>
										</value>
									</Operation>
								</caseTrue>
							</Operation>
						</apply>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
