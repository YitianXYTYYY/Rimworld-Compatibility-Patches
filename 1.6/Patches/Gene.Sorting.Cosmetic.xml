<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>Ludeon.RimWorld.Biotech</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<!-- -98 voice -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneVoiceBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Voice</displayCategory>
				</value>
			</Operation>

			<!-- -99 hairstyle -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneHairStyleBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Head_Hair</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[defName="Hair_Grayless"]</xpath>
				<value>
					<biostatCpx Operation="AddOrReplace">0</biostatCpx>
					<displayCategory Operation="AddOrReplace">Cosmetic_Head_Hair</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.phytokin</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_FoliageHair"]</xpath>
						<value>
							<biostatCpx Operation="AddOrReplace">0</biostatCpx>
							<displayCategory Operation="SafeRemove"/>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.sanguophage</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_SanguineHair"]</xpath>
						<value>
							<displayCategory Operation="SafeRemove"/>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- -100 cosmetic -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.fungoid</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_FacialSpots"]</xpath>
						<value>
							<biostatCpx  Operation="AddOrReplace">0</biostatCpx>
							<displayCategory Operation="AddOrReplace">Cosmetic</displayCategory>
							<iconColor Operation="SafeAdd">(0.75, 0.75, 0.75)</iconColor>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- -101 jaw -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneJawBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Head_Jaw</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.genie</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_ElongatedHead"]</xpath>
						<value>
							<biostatCpx Operation="AddOrReplace">0</biostatCpx>
							<displayCategory Operation="SafeRemove"/>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.pigskin</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_MouthTusks"]</xpath>
						<value>
							<biostatCpx Operation="AddOrReplace">0</biostatCpx>
							<displayCategory Operation="AddOrReplace">Cosmetic_Head_Jaw</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">1000</displayOrderInCategory>
							<iconColor Operation="AddOrReplace">(0.75, 0.75, 0.75)</iconColor>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- -102 beard -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneBeardStyleBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Head_Beard</displayCategory>
				</value>
			</Operation>

			<!-- -103 headbone -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneHeadboneBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Head_Headbone</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>JintuziLamian.Gene.XenoCosmetic</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[@Name="AFU_HeadboneGeneBase"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Cosmetic_Head_Headbone</displayCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.insector</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_InsectAntennae"]</xpath>
						<value>
							<biostatCpx Operation="AddOrReplace">0</biostatCpx>
							<displayCategory Operation="AddOrReplace">Cosmetic_Head_Headbone</displayCategory>
							<iconColor Operation="AddOrReplace">(0.75, 0.75, 0.75)</iconColor>
							<exclusionTags Operation="Safe">
								<li Operation="SafeAdd" Compare="InnerText">Headbone</li>
							</exclusionTags>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- -104 ear -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneEarsBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Head_Ear</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>JintuziLamian.Gene.XenoCosmetic</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[@Name="AFU_HeadAttachmentGeneBase"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Cosmetic_Head_Ear</displayCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.lycanthrope</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_CanineEars"]</xpath>
						<value>
							<biostatCpx Operation="AddOrReplace">0</biostatCpx>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- -105 nose -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneNoseBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Head_Nose</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.PatchOperationSafeRemove">
				<xpath>Defs/GeneDef[defName="Nose_Pig"]/displayCategory</xpath>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.lycanthrope</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_CanineNose"]</xpath>
						<value>
							<biostatCpx Operation="AddOrReplace">0</biostatCpx>
							<displayCategory Operation="SafeRemove"/>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.sanguophage</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_BatNose"]</xpath>
						<value>
							<displayCategory Operation="SafeRemove"/>
						</value>
					</Operation>
				</caseTrue>
			</Operation>


			<!-- -110 bodytype -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneBodyBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_BodyType</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.waster</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_GauntBody"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Cosmetic_BodyType</displayCategory>
							<iconColor Operation="AddOrReplace">(0.75, 0.75, 0.75)</iconColor>
							<exclusionTags Operation="Safe">
								<li Operation="SafeAdd" Compare="InnerText">BodyType</li>
							</exclusionTags>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- -111 hand -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneHandsBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Body_ArmHand</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>resplice.xotr.core</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[@Name="RS_GeneTentacleBase"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Cosmetic_Body_ArmHand</displayCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- -112 wing -->
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.hussar</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VREH_Glidewings"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Cosmetic_Body_Wing</displayCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- -113 tail -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneTailBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Body_Tail</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>JintuziLamian.Gene.XenoCosmetic</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.SetScope">
						<xpath>Defs/GeneDef[@Name="AFU_BodyAttachmentGeneBase"]</xpath>
						<apply>
							<Operation Class="XmlExtensions.HybridPatch">
								<xpath>GeneDef</xpath>
								<value>
									<displayCategory Operation="AddOrReplace">Cosmetic_Body_Tail</displayCategory>
								</value>
							</Operation>
							<Operation Class="XmlExtensions.FindMod">
								<mods>
									<li>RedMattis.BetterPrerequisites</li>
								</mods>
								<packageId>true</packageId>
								<caseTrue>
									<Operation Class="XmlExtensions.PatchOperationAddModExtension">
										<xpath>GeneDef</xpath>
										<value>
											<li Class="BigAndSmall.PawnExtension">
												<thingDefSwap>BS_HumanoidWithTail</thingDefSwap>
											</li>
										</value>
									</Operation>
								</caseTrue>
							</Operation>
						</apply>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.pigskin</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_CurledTail"]</xpath>
						<value>
							<iconColor Operation="AddOrReplace">(0.75, 0.75, 0.75)</iconColor>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.saurid</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRESaurids_GeckoTail"]</xpath>
						<value>
							<biostatCpx Operation="AddOrReplace">0</biostatCpx>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.starjack</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VREStarjack_SpacejumpLegs"]</xpath>
						<value>
							<displayCategory Operation="SafeRemove"/>
							<iconColor Operation="AddOrReplace">(0.75, 0.75, 0.75)</iconColor>
						</value>
					</Operation>
				</caseTrue>
			</Operation>

			<!-- -1000 haircolor -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneHairColorBase"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Head_HairColor</displayCategory>
				</value>
			</Operation>

			<!-- -1001 eyecolor -->
			<Operation Class="XmlExtensions.HybridPatch">
				<xpath>Defs/GeneDef[@Name="GeneEyeColor"]</xpath>
				<value>
					<displayCategory Operation="AddOrReplace">Cosmetic_Head_EyeColor</displayCategory>
				</value>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>oppey.eyegenes2</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[@Name="EyeGenes2Cosmetical"]</xpath>
						<value>
							<displayCategory Operation="AddOrReplace">Cosmetic_Head_EyeColor</displayCategory>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
		</caseTrue>
	</Operation>

</Patch>
