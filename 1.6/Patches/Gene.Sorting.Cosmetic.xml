<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- -10 skin -->
	<Operation Class="XmlExtensions.FindMod">
		<mods>
			<li>ludeon.rimworld.biotech</li>
		</mods>
		<packageId>true</packageId>
		<caseTrue>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.phytokin</li>
				</mods>
				<packageId>true</packageId>
				<caseTrue>
					<Operation Class="XmlExtensions.HybridPatch">
						<xpath>Defs/GeneDef[defName="VRE_BarkSkin"]</xpath>
						<value>
							<biostatMet Operation="SafeReplace">-2</biostatMet>
							<displayCategory Operation="AddOrReplace">Skin</displayCategory>
							<displayOrderInCategory Operation="AddOrReplace">0</displayOrderInCategory>
							<statOffsets Operation="Safe">
								<ArmorRating_Blunt Operation="SafeReplace">0.40</ArmorRating_Blunt>
							</statOffsets>
						</value>
					</Operation>
				</caseTrue>
			</Operation>
			<Operation Class="XmlExtensions.FindMod">
				<mods>
					<li>vanillaracesexpanded.lycanthrope</li>
				</mods>
