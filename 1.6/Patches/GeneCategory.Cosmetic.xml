<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<Operation Class="PatchOperationRemove">
		<xpath>Defs/GeneCategoryDef[defName="Cosmetic" or defName="Cosmetic_Skin"]/displayPriorityInGenepack</xpath>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneCategoryDef[defName="Cosmetic"]/displayPriorityInXenotype</xpath>
		<value>
			<displayPriorityInXenotype>-100</displayPriorityInXenotype>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneCategoryDef[defName="Cosmetic_Skin"]/displayPriorityInXenotype</xpath>
		<value>
			<displayPriorityInXenotype>-110</displayPriorityInXenotype>
		</value>
	</Operation>

	<!-- <Base Game Genes -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneHairStyleBase" or @Name="GeneBeardStyleBase" or @ParentName="GeneHairStyleBase" or @ParentName="GeneBeardStyleBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Head_Hair</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneHairColorBase" or @ParentName="GeneHairColorBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Head_HairColor</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneVoiceBase" or @ParentName="GeneVoiceBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Voice</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneJawBase" or @ParentName="GeneJawBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Head_Jaw</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneHeadboneBase" or @ParentName="GeneHeadboneBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Head_Headbone</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneEarsBase" or @ParentName="GeneEarsBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Head_Ear</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneEyeColor" or @ParentName="GeneEyeColor"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Head_EyeColor</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneNoseBase" or @ParentName="GeneNoseBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Head_Nose</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneBodyBase" or @ParentName="GeneBodyBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_BodyType</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneHandsBase" or @ParentName="GeneHandsBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Body_ArmHand</displayCategory>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/GeneDef[@Name="GeneTailBase" or @ParentName="GeneTailBase"]/displayCategory</xpath>
		<value>
			<displayCategory>Cosmetic_Body_Tail</displayCategory>
		</value>
	</Operation>

	<!-- Mod Genes -->
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>AFU Cosmetic Gene Expanded</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[@Name="AFU_HeadboneGeneBase"]/displayCategory</xpath>
					<value>
						<displayCategory>Cosmetic_Head_Headbone</displayCategory>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[@Name="AFU_HeadAttachmentGeneBase"]/displayCategory</xpath>
					<value>
						<displayCategory>Cosmetic_Head_Ear</displayCategory>
					</value>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[@Name="AFU_BodyAttachmentGeneBase"]/displayCategory</xpath>
					<value>
						<displayCategory>Cosmetic_Body_Tail</displayCategory>
					</value>
				</li>
				<li Class="PatchOperationFindMod">
					<mods>
						<li>Big and Small - Framework</li>
					</mods>
					<match Class="PatchOperationAddModExtension">
						<xpath>Defs/GeneDef[@Name="AFU_BodyAttachmentGeneBase"]</xpath>
						<value>
							<li Class="BigAndSmall.PawnExtension">
								<thingDefSwap>BS_HumanoidWithTail</thingDefSwap>
							</li>
						</value>
					</match>
				</li>
				<li Class="PatchOperationReplace">
					<xpath>Defs/GeneDef[@ParentName="AFU_HeadboneGeneBase" or @ParentName="AFU_HeadAttachmentGeneBase" or @ParentName="AFU_BodyAttachmentGeneBase"]/displayOrderInCategory</xpath>
					<value>
						<displayOrderInCategory>-100</displayOrderInCategory>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>[BT] EyeGenes2 | Base - [NL] Facial Animation |</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/GeneDef[@Name="EyeGenes2Cosmetical"]/displayCategory</xpath>
			<value>
				<displayCategory>Cosmetic_Head_EyeColor</displayCategory>
			</value>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>ReSplice: Core</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/GeneDef[@Name="RS_GeneTentacleBase"]/displayCategory</xpath>
			<value>
				<displayCategory>Cosmetic_Body_ArmHand</displayCategory>
			</value>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Lycanthrope</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/GeneDef[@Name="VRE_BodyBaseLycans"]/displayCategory</xpath>
			<value>
				<displayCategory>Health_Skin</displayCategory>
			</value>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Phytokin</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/GeneDef[@Name="VRE_BodyBase"]/displayCategory</xpath>
			<value>
				<displayCategory>Health_Skin</displayCategory>
			</value>
		</match>
	</Operation>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Races Expanded - Insector</li>
		</mods>
		<match Class="PatchOperationReplace">
			<xpath>Defs/GeneDef[@Name="VRE_BodyBaseInsect"]/displayCategory</xpath>
			<value>
				<displayCategory>Health_Skin</displayCategory>
			</value>
		</match>
	</Operation>

</Patch>
